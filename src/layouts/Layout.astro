---
import { siteData } from '../data/site';
import '../styles/global.css';
import ChatbotWidget from '../components/ChatbotWidget.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = siteData.name, 
  description = siteData.shortBio 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Premium Fonts matching Diegoliv -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oswald:wght@700;900&display=swap" rel="stylesheet">
  </head>
  <body class="antialiased selection:bg-black selection:text-white" style="background-color: #F2F2F2; color: #000000;">
    
    <!-- Blue Glow Vignette (Subtle Liquid Glass edge) -->
    <div class="fixed inset-0 pointer-events-none z-[100] shadow-[inset_0_0_120px_rgba(0,102,255,0.08)] mix-blend-multiply"></div>

    <!-- Diegoliv Character Grid Pattern -->
    <div class="fixed inset-0 pointer-events-none z-0 opacity-[0.04] pattern-grid"></div>

    <main class="relative z-10 w-full overflow-hidden" id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </main>

    <!-- N8N CHATBOT WIDGET -->
    <div class="relative z-[150]">
        <ChatbotWidget />
    </div>

    <!-- LENIS SMOOTH SCROLL -->
    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Initialize Lenis exactly like DiegoLiv for that silky feel
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: true,
        touchMultiplier: 2,
      });

      lenis.on('scroll', ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0, 0);

      // Magnetic Effect - ONLY on CTA buttons (not text nav links to avoid jumping)
      const magnets = document.querySelectorAll('.cta-magnetic');
      magnets.forEach((magnet) => {
          magnet.addEventListener('mousemove', (e) => {
              const pos = magnet.getBoundingClientRect();
              const x = e.clientX - pos.left - pos.width / 2;
              const y = e.clientY - pos.top - pos.height / 2;
              gsap.to(magnet, { x: x * 0.2, y: y * 0.2, duration: 0.4, ease: 'power2.out' });
          });
          magnet.addEventListener('mouseleave', () => {
              gsap.to(magnet, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, 0.4)' });
          });
      });
    </script>

    <style is:global>
      :root {
        --bg: #F2F2F2;
        --text: #000000;
        --accent: #0066ff;
      }
      
      html.lenis, html.lenis body {
        height: auto;
      }

      .lenis.lenis-smooth {
        scroll-behavior: auto !important;
      }

      .lenis.lenis-smooth [data-lenis-prevent] {
        overscroll-behavior: contain;
      }

      .lenis.lenis-stopped {
        overflow: hidden;
      }

      .lenis.lenis-scrolling iframe {
        pointer-events: none;
      }

      /* Character Grid Texture using SVG Data URI (Matches DiegoLiv background noise) */
      .pattern-grid {
        background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Ctext x='15' y='25' font-family='monospace' font-size='12' fill='%23000'%3E+%3C/text%3E%3Ctext x='55' y='65' font-family='monospace' font-size='12' fill='%23000'%3E-%3C/text%3E%3Ctext x='15' y='65' font-family='monospace' font-size='12' fill='%23000'%3E.%3C/text%3E%3Ctext x='55' y='25' font-family='monospace' font-size='12' fill='%23000'%3E*%3C/text%3E%3C/svg%3E");
        background-repeat: repeat;
      }

      /* Huge UI Typography */
      h1, h2, h3, h4, .font-heading {
        font-family: 'Oswald', 'Inter', sans-serif;
        text-transform: uppercase;
        font-weight: 900 !important;
        letter-spacing: -0.03em;
        line-height: 0.85;
      }
      
      p, a, span, .font-sans {
        font-family: 'Inter', sans-serif;
      }
      
      /* Global border radius for the diegoliv card style */
      .stadium-pill {
        border-radius: 200px;
      }
      
      .diegoliv-card {
        border-radius: 48px;
        background: #ffffff;
        box-shadow: 0 20px 40px rgba(0,0,0,0.03);
      }
      
      /* Mobile Fixes for Inputs */
      @media screen and (max-width: 768px) {
        input, select, textarea {
          font-size: 16px !important;
        }
      }
    </style>
  </body>
</html>
