---
---

<section id="contacto" class="bg-white text-black pt-16 pb-8 px-4 flex flex-col items-center justify-between min-h-[40vh] relative overflow-hidden">
  
  <div class="w-full max-w-6xl mx-auto flex flex-col items-center justify-center relative z-10 mb-12">
    
    <!-- Pill Footer Banner -->
    <div class="w-full h-[25vh] md:h-[30vh] rounded-[100px] overflow-hidden relative shadow-2xl flex items-center justify-center cursor-pointer" id="footer-pill-btn">
      <!-- Background Image -->
      <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80" alt="Work Background" class="absolute inset-0 w-full h-full object-cover blur-[2px] brightness-50" />
      
      <!-- Overlay Text -->
      <div class="relative z-10 text-center px-6">
        <h2 class="font-heading text-4xl md:text-6xl lg:text-[80px] font-black text-white uppercase tracking-tighter leading-[0.85] shadow-black drop-shadow-2xl">
          ARMEMOS <br/>
          TU SISTEMA <br/>
          JUNTOS
        </h2>
      </div>
    </div>

  </div>

  <!-- Bottom Bar Links -->
  <div class="w-full flex flex-col items-center gap-8 relative z-10 text-center">
    <div class="flex flex-wrap justify-center gap-6 md:gap-8 font-sans text-[10px] md:text-xs font-bold uppercase tracking-widest text-black">
      <a href="https://linkedin.com" target="_blank" class="hover:text-[#0066ff] transition-colors">LINKEDIN</a>
      <a href="https://github.com" target="_blank" class="hover:text-[#0066ff] transition-colors">GITHUB</a>
      <a href="https://instagram.com" target="_blank" class="hover:text-[#0066ff] transition-colors">INSTAGRAM</a>
      <button id="btn-whatsapp-footer2" class="hover:text-[#25D366] transition-colors uppercase cursor-pointer">WHATSAPP</button>
    </div>
    
    <span class="font-sans text-[10px] md:text-xs font-medium text-black/60">
      Juan Esteban Ospina &copy; 2026. Gracias por pasarte.
    </span>
  </div>

</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
      const wppBtn2 = document.getElementById('btn-whatsapp-footer2');
      const pillBtn = document.getElementById('footer-pill-btn');
      
      const fireWpp = () => {
          const phoneNumber = '573245638720';
          const message = "Hola Juan Esteban, quisiera cotizar la arquitectura o backend de un nuevo proyecto.";
          const encodedMessage = encodeURIComponent(message);
          window.open(`https://wa.me/${phoneNumber}?text=${encodedMessage}`, '_blank');
      };

      if (wppBtn2) wppBtn2.addEventListener('click', fireWpp);
      if (pillBtn) pillBtn.addEventListener('click', fireWpp);
  });
</script>
