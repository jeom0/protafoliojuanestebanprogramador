---
---

<section id="contacto" class="bg-[#f8fafc] w-full min-h-[90vh] flex flex-col items-center justify-between pt-32 pb-8 px-4 md:px-12 border-t border-black/10 relative overflow-hidden">
  
  <div class="w-full max-w-[1400px] mx-auto flex flex-col items-center justify-center flex-1 text-center relative z-10">
    
    <p class="font-sans text-[10px] md:text-xs font-black uppercase tracking-[0.3em] text-[#0066ff] mb-4">
      ¿TIENES UNA IDEA?
    </p>

    <!-- Professional Contact Form -->
    <div class="w-full max-w-2xl mx-auto mb-32 bg-white rounded-[32px] p-8 md:p-12 shadow-[0_20px_60px_rgba(0,0,0,0.05)] border border-black/5 text-left">
      <h3 class="font-heading text-3xl font-black uppercase tracking-tighter text-black mb-8">Ponte en contacto</h3>
      <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-6">
        <!-- Reemplaza esto con tu Access Key de Web3Forms -->
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">
        
        <div class="flex flex-col md:flex-row gap-6">
          <div class="flex-1 flex flex-col gap-2">
            <label for="name" class="font-sans text-[10px] font-bold uppercase tracking-widest text-black/60">Tu Nombre</label>
            <input type="text" id="name" name="name" required class="w-full bg-[#f8fafc] border border-black/10 rounded-xl px-4 py-3 font-sans text-sm focus:outline-none focus:border-black transition-colors" placeholder="Juan Pérez">
          </div>
          <div class="flex-1 flex flex-col gap-2">
            <label for="email" class="font-sans text-[10px] font-bold uppercase tracking-widest text-black/60">Tu Email</label>
            <input type="email" id="email" name="email" required class="w-full bg-[#f8fafc] border border-black/10 rounded-xl px-4 py-3 font-sans text-sm focus:outline-none focus:border-black transition-colors" placeholder="juan@empresa.com">
          </div>
        </div>
        
        <div class="flex flex-col gap-2">
          <label for="message" class="font-sans text-[10px] font-bold uppercase tracking-widest text-black/60">Mensaje</label>
          <textarea id="message" name="message" rows="4" required class="w-full bg-[#f8fafc] border border-black/10 rounded-xl px-4 py-3 font-sans text-sm focus:outline-none focus:border-black transition-colors resize-none" placeholder="Cuéntame sobre tu proyecto o idea..."></textarea>
        </div>

        <button type="submit" class="mt-4 px-8 py-4 rounded-xl bg-black text-white font-sans text-xs uppercase font-black tracking-widest hover:bg-[#0066ff] transition-colors w-full md:w-auto self-start">
          ENVIAR MENSAJE
        </button>
      </form>
    </div>

    <!-- Giant WhatsApp Trigger -->
    <p class="font-sans text-[10px] md:text-xs font-black uppercase tracking-[0.3em] text-[#0066ff] mb-8">
      O ESCRÍBEME DIRECTAMENTE
    </p>
    <h2 class="font-heading text-[10vw] md:text-[8vw] lg:text-[120px] font-black text-black uppercase tracking-tighter leading-[0.85] mb-12 hover:scale-105 transition-transform duration-700 cursor-pointer" id="giant-contact-btn">
      CONSTRUYAMOS<br/>
      ALGO GENIAL.
    </h2>

    <a href="mailto:jeom.245@gmail.com" class="px-8 py-4 rounded-full bg-black text-white font-sans text-xs uppercase font-black tracking-widest hover:bg-[#0066ff] transition-colors shadow-2xl flex items-center gap-3">
      ENVIAR CORREO
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>

  </div>

  <!-- Absolute Bottom Bar -->
  <div class="w-full max-w-[1400px] mt-32 pt-8 border-t border-black/10 flex flex-col md:flex-row justify-between items-center gap-6 relative z-10">
    
    <span class="font-sans text-[10px] font-bold text-black/40 uppercase tracking-widest">
      &copy; 2026 JUAN ESTEBAN OSPINA. ALL RIGHTS RESERVED.
    </span>

    <div class="flex items-center gap-8 font-sans text-[10px] font-bold uppercase tracking-widest text-black">
      <a href="https://linkedin.com" target="_blank" class="hover:text-[#0066ff] transition-colors">LINKEDIN</a>
      <a href="https://github.com" target="_blank" class="hover:text-[#0066ff] transition-colors">GITHUB</a>
      <a href="https://instagram.com" target="_blank" class="hover:text-[#0066ff] transition-colors">INSTAGRAM</a>
      <button id="btn-whatsapp-footer2" class="hover:text-[#25D366] transition-colors uppercase cursor-pointer">WHATSAPP</button>
    </div>

  </div>

  <!-- Background Glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[80vw] h-[50vh] bg-[#0066ff]/5 blur-[120px] rounded-[100%] pointer-events-none z-0"></div>

</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
      const wppBtn2 = document.getElementById('btn-whatsapp-footer2');
      const giantBtn = document.getElementById('giant-contact-btn');
      
      const fireWpp = () => {
          const phoneNumber = '573245638720';
          const message = "Hola Juan Esteban, me encantó tu portafolio y quisiera cotizar un proyecto.";
          const encodedMessage = encodeURIComponent(message);
          window.open(`https://wa.me/${phoneNumber}?text=${encodedMessage}`, '_blank');
      };

      if (wppBtn2) wppBtn2.addEventListener('click', fireWpp);
      if (giantBtn) giantBtn.addEventListener('click', fireWpp);
  });
</script>
