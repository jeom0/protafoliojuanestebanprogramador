---

<section id="contacto" class="py-12 bg-[#F2F2F2] overflow-hidden min-h-screen flex items-end">
  <div class="container mx-auto px-4 w-full">
    
    <!-- Stadium Footer Card -->
    <div class="stadium-pill bg-black w-full pt-32 pb-16 px-8 md:px-16 flex flex-col items-center justify-between min-h-[85vh] relative overflow-hidden text-center shadow-2xl">
        
        <!-- Animated Background Glow -->
        <div class="absolute inset-0 z-0 bg-gradient-to-t from-[#0066ff]/20 to-transparent opacity-40"></div>
        <div class="absolute w-[600px] h-[600px] bg-[#0066ff] rounded-full blur-[120px] opacity-10 -bottom-[300px] left-1/2 -translate-x-1/2 animate-pulse"></div>
        
        <!-- Header Text -->
        <div class="relative z-10 w-full flex flex-col items-center">
            <span class="px-6 py-2 rounded-full border border-white/20 text-white/60 font-sans text-xs uppercase font-bold tracking-widest bg-white/5 backdrop-blur-md mb-12">
                DISPONIBLE PARA NUEVOS PROYECTOS
            </span>
            
            <!-- Massive Footer Headline -->
            <a href="mailto:juanospina@example.com" class="group relative z-10 inline-block overflow-hidden">
                <h2 class="font-heading text-[12vw] sm:text-[14vw] md:text-[12vw] uppercase font-black text-white tracking-tighter leading-[0.85] w-full text-center transition-transform duration-500 group-hover:scale-105 group-hover:text-[#0066ff] mix-blend-screen">
                    TRABAJEMOS <br/>
                    <i class="opacity-40 group-hover:opacity-100 transition-opacity">JUNTOS.</i>
                </h2>
                <!-- Hover underline animation -->
                <div class="absolute bottom-4 left-[10%] w-[80%] h-2 bg-[#0066ff] scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-500"></div>
            </a>
            
            <p class="font-sans text-white/50 text-xl md:text-2xl max-w-2xl mt-12 font-medium leading-relaxed">
                ¿Tienes una idea en mente o necesitas escalar la arquitectura de tu startup? Escríbeme y hagámoslo fluido.
            </p>

            <!-- Quick Action Buttons -->
            <div class="mt-16 flex flex-col sm:flex-row gap-4 items-center justify-center">
                <a href="mailto:juanospina@example.com" class="px-10 py-5 bg-white text-black font-sans text-sm uppercase font-bold tracking-widest rounded-full hover:bg-black hover:text-white border border-transparent hover:border-white/20 transition-all duration-300 transform hover:-translate-y-1 shadow-[0_10px_30px_rgba(255,255,255,0.2)] hover:shadow-none">
                    ENVIAR CORREO
                </a>
                
                <!-- Specialized WhatsApp Button -->
                <button type="button" id="btn-whatsapp-footer" class="px-10 py-5 bg-[#25D366] text-black font-sans text-sm uppercase font-bold tracking-widest rounded-full hover:bg-[#128C7E] hover:text-white transition-all duration-300 transform hover:-translate-y-1 shadow-[0_10px_30px_rgba(37,211,102,0.3)] flex items-center gap-3">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.993 0C5.367 0 0 5.366 0 11.995c0 2.65.86 5.105 2.308 7.15L.892 24l5.006-1.314c1.954 1.258 4.29 1.986 6.784 1.986C19.317 24 24 18.634 24 12c0-6.63-5.366-12-12.007-12zm6.657 17.185c-.279.789-1.545 1.517-2.128 1.579-.536.056-1.228.096-3.411-.806-2.774-1.144-4.551-4.008-4.691-4.194-.14-.186-1.121-1.492-1.121-2.844 0-1.352.704-2.016.953-2.28.249-.264.544-.33.722-.33.179 0 .358.008.514.016.163.008.381-.062.599.467.225.544 1.057 2.58.1149 2.766.093.187-.031.296-.124.436-.093.14-.194.303-.279.389-.093.093-.194.194-.085.381.109.187.482.793 1.034 1.284.711.63 1.306.824 1.492.918.187.093.296.078.405-.031.109-.109.474-.552.599-.739.124-.187.249-.156.419-.093.171.062 1.081.513 1.267.607.187.093.311.14.358.218.047.078.047.451-.233 1.24z"/></svg>
                    WHATSAPP DIRECTO
                </button>
            </div>
        </div>

        <!-- Footer Bottom Links -->
        <div class="relative z-10 w-full mt-32 border-t border-white/10 pt-10 flex flex-col md:flex-row justify-between items-center gap-6 pb-4">
            <span class="font-sans text-xs font-bold uppercase tracking-widest text-[#0066ff]">&copy; 2026 OSPINA_DEV</span>
            <div class="flex gap-8">
                <a href="#" class="font-sans text-xs font-bold uppercase tracking-widest text-white/40 hover:text-white transition-colors">LINKEDIN</a>
                <a href="#" class="font-sans text-xs font-bold uppercase tracking-widest text-white/40 hover:text-white transition-colors">GITHUB</a>
                <a href="#" class="font-sans text-xs font-bold uppercase tracking-widest text-white/40 hover:text-white transition-colors">INSTAGRAM</a>
            </div>
            <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/20">MADE IN COLOMBIA</span>
        </div>
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
      // WhatsApp Quote Logic Native
      const wppBtn = document.getElementById('btn-whatsapp-footer');
      if (wppBtn) {
          wppBtn.addEventListener('click', () => {
              const phoneNumber = '573214567890'; // Use actual phone number
              const message = "Hola Juan Esteban, quisiera cotizar la arquitectura o backend de un nuevo proyecto.";
              const encodedMessage = encodeURIComponent(message);
              window.open(`https://wa.me/${phoneNumber}?text=${encodedMessage}`, '_blank');
          });
      }
  });
</script>
