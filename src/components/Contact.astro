---
---

<section id="contacto" class="bg-[#111] text-white pt-24 md:pt-40 pb-8 px-6 md:px-12 flex flex-col justify-between min-h-screen relative overflow-hidden">
  
  <div class="flex-1 flex flex-col justify-center w-full z-10 relative">
    <!-- Huge Typography DiegoLiv Style -->
    <div class="w-full flex justify-start mb-2 md:mb-0">
      <h2 data-gsap="footer-title-1" class="font-heading text-[18vw] sm:text-[15vw] leading-[0.8] tracking-tighter uppercase font-black text-white/90 transform translate-y-20 opacity-0">TRABAJEMOS</h2>
    </div>
    <div class="w-full flex justify-end">
      <h2 data-gsap="footer-title-2" class="font-heading text-[18vw] sm:text-[15vw] leading-[0.8] tracking-tighter uppercase font-black text-[#0066ff] transform translate-y-20 opacity-0">JUNTOS.</h2>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mt-24 md:mt-32 z-10 relative">
    <!-- Email & Action -->
    <div class="flex flex-col items-start gap-6">
      <p class="font-sans text-xs md:text-sm uppercase tracking-widest text-[#0066ff] font-bold">Inicia un proyecto</p>
      <a href="mailto:juanospina@example.com" class="magnetic-btn font-sans text-3xl md:text-5xl font-light hover:text-[#0066ff] transition-colors">juanospina@example.com</a>
      
      <button type="button" id="btn-whatsapp-footer" class="magnetic-btn mt-6 px-10 py-5 bg-[#25D366] text-black font-sans text-xs uppercase font-bold tracking-widest rounded-full hover:bg-[#128C7E] hover:text-white transition-all transform flex items-center gap-3">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.993 0C5.367 0 0 5.366 0 11.995c0 2.65.86 5.105 2.308 7.15L.892 24l5.006-1.314c1.954 1.258 4.29 1.986 6.784 1.986C19.317 24 24 18.634 24 12c0-6.63-5.366-12-12.007-12zm6.657 17.185c-.279.789-1.545 1.517-2.128 1.579-.536.056-1.228.096-3.411-.806-2.774-1.144-4.551-4.008-4.691-4.194-.14-.186-1.121-1.492-1.121-2.844 0-1.352.704-2.016.953-2.28.249-.264.544-.33.722-.33.179 0 .358.008.514.016.163.008.381-.062.599.467.225.544 1.057 2.58.1149 2.766.093.187-.031.296-.124.436-.093.14-.194.303-.279.389-.093.093-.194.194-.085.381.109.187.482.793 1.034 1.284.711.63 1.306.824 1.492.918.187.093.296.078.405-.031.109-.109.474-.552.599-.739.124-.187.249-.156.419-.093.171.062 1.081.513 1.267.607.187.093.311.14.358.218.047.078.047.451-.233 1.24z"/></svg>
          WHATSAPP DIRECTO
      </button>
    </div>

    <!-- Socials / Links -->
    <div class="flex flex-col md:items-end gap-6">
      <p class="font-sans text-xs md:text-sm uppercase tracking-widest text-[#0066ff] font-bold">Nodos Sociales</p>
      <div class="flex flex-col gap-2 md:text-right">
        <a href="#" class="magnetic-btn font-sans text-3xl md:text-5xl font-light hover:text-[#0066ff] transition-colors relative group">
            LinkedIn <span class="absolute -bottom-1 left-0 w-0 h-1 bg-[#0066ff] transition-all group-hover:w-full md:left-auto md:right-0"></span>
        </a>
        <a href="#" class="magnetic-btn font-sans text-3xl md:text-5xl font-light hover:text-[#0066ff] transition-colors relative group">
            GitHub <span class="absolute -bottom-1 left-0 w-0 h-1 bg-[#0066ff] transition-all group-hover:w-full md:left-auto md:right-0"></span>
        </a>
        <a href="#" class="magnetic-btn font-sans text-3xl md:text-5xl font-light hover:text-[#0066ff] transition-colors relative group">
            Instagram <span class="absolute -bottom-1 left-0 w-0 h-1 bg-[#0066ff] transition-all group-hover:w-full md:left-auto md:right-0"></span>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="mt-24 md:mt-32 pt-10 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] md:text-xs font-sans uppercase tracking-[0.2em] font-bold text-white/40 z-10 relative">
    <span>&copy; 2026 JUAN ESTEBAN OSPINA</span>
    <span class="flex items-center gap-3">
        BACKEND ENGINEER <span class="w-1.5 h-1.5 rounded-full bg-[#0066ff] animate-pulse"></span> UBICADO EN COLOMBIA
    </span>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
      // WhatsApp Quote Logic Native
      const wppBtn = document.getElementById('btn-whatsapp-footer');
      if (wppBtn) {
          wppBtn.addEventListener('click', () => {
              const phoneNumber = '573214567890'; // Use actual phone number
              const message = "Hola Juan Esteban, quisiera cotizar la arquitectura o backend de un nuevo proyecto.";
              const encodedMessage = encodeURIComponent(message);
              window.open(`https://wa.me/${phoneNumber}?text=${encodedMessage}`, '_blank');
          });
      }
  });
</script>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // Massive Typography Entrance
        const title1 = document.querySelector('[data-gsap="footer-title-1"]');
        const title2 = document.querySelector('[data-gsap="footer-title-2"]');
        
        if(title1 && title2) {
            gsap.to([title1, title2], {
                y: 0,
                opacity: 1,
                duration: 1.5,
                stagger: 0.2,
                ease: 'power4.out',
                scrollTrigger: {
                    trigger: "#contacto",
                    start: "top 60%", // Trigger when footer enters screen
                    toggleActions: "play none none reverse"
                }
            });
        }
    });
</script>
