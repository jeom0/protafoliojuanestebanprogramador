---
---

<section id="contacto" class="py-16 relative overflow-hidden border-t" style="border-color:rgba(255,255,255,0.06);">
  
  <div class="container mx-auto px-6 relative z-10 w-full h-full flex flex-col justify-center">
    
    <!-- HEADER -->
    <div class="flex flex-col items-center text-center mb-16 reveal-on-scroll">
        <span class="px-5 py-2 rounded-full text-[10px] font-black tracking-widest uppercase mb-8 inline-block border shadow-sm" style="background:rgba(16,185,129,0.1); color:#6ee7b7; border-color:rgba(16,185,129,0.2);">
            Cotización Abierta
        </span>
        <h2 class="font-heading text-4xl sm:text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.85] font-black max-w-4xl pb-2 break-words" style="color:#f1f5f9;">
            TECNOLOGÍA REFINADA. <br/> <span class="text-blue-500 italic drop-shadow-2xl">HABLEMOS.</span>
        </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 max-w-6xl mx-auto w-full">
      
      <!-- INFO COLUMN -->
      <div class="lg:col-span-5 rounded-[2.5rem] p-10 md:p-14 flex flex-col justify-between reveal-on-scroll delay-100 overflow-hidden relative bento-interactive" style="background:linear-gradient(135deg, rgba(5,150,105,0.12) 0%, rgba(17,24,39,0.8) 100%);">
        <div class="absolute -right-20 -bottom-20 w-80 h-80 rounded-full" style="background:rgba(16,185,129,0.08); filter:blur(60px);"></div>
        
        <div class="relative z-10">
            <h3 class="text-4xl font-bold mb-6 tracking-tight" style="color:#f1f5f9;">Vías de Contacto</h3>
            <p class="font-light mb-12 text-lg" style="color:#64748b;">
                Elige el canal más cómodo para ti. Respondo cotizaciones en menos de 24 horas.
            </p>
            
            <div class="space-y-6">
                <div class="p-6 rounded-2xl transition-colors" style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);">
                    <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color:#34d399;">Respuesta Inmediata</p>
                    <a href="https://wa.me/573000000000" target="_blank" class="text-2xl font-bold flex items-center gap-4 transition-colors" style="color:#f1f5f9;">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" style="color:#25D366;"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.898-4.45 9.898-9.896 0-2.679-1.044-5.198-2.939-7.093-1.894-1.895-4.414-2.94-7.09-2.94-5.45 0-9.899 4.45-9.899 9.896 0 1.712.445 3.292 1.328 4.782l-1.151 4.205 4.461-1.15zM17.476 14.51c-.244-.122-1.446-.714-1.669-.796-.223-.082-.385-.122-.547.122-.162.244-.649.796-.798.96-.149.162-.298.183-.542.061-1.353-.668-2.607-1.498-3.702-2.457-.831-.727-1.49-1.598-1.954-2.559-.112-.23.014-.356.136-.477.109-.108.244-.285.366-.427.122-.142.162-.244.244-.407.082-.162.041-.305-.02-.427-.061-.122-.547-1.321-.749-1.808-.2-.477-.404-.412-.547-.42-.142-.007-.305-.007-.468-.007-.162 0-.427.061-.649.305-.224.244-.852.833-.852 2.035 0 1.201.872 2.364.994 2.527.122.162 1.725 2.631 4.18 3.633 1.944.793 2.583.743 3.19.689.654-.058 1.446-.591 1.648-1.163.203-.571.203-1.059.142-1.163-.061-.104-.224-.165-.468-.287z"/></svg>
                        WhatsApp
                    </a>
                </div>
                
                <div class="p-6 rounded-2xl transition-colors" style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);">
                    <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color:#60a5fa;">Email Dedicado</p>
                    <a href="mailto:hola@juanesteban.dev" class="text-xl font-bold flex items-center gap-4 transition-colors" style="color:#f1f5f9;">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:#3b82f6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        hola@juanesteban.dev
                    </a>
                </div>
            </div>
        </div>
      </div>

      <!-- FORM COLUMN -->
      <div class="lg:col-span-7 p-8 md:p-12 rounded-[2.5rem] reveal-on-scroll delay-200 relative overflow-hidden bento-interactive">
        <div class="mb-8">
            <h3 class="text-2xl font-bold" style="color:#f1f5f9;">Formulario de Cotización</h3>
            <p class="text-sm mt-2" style="color:#475569;">Detalla tu requerimiento para una evaluación precisa.</p>
        </div>
        
        <form id="quote-form-v18" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
                <label class="font-bold text-xs uppercase tracking-widest" style="color:#64748b;">Nombre Completo</label>
                <input type="text" id="q-name" required placeholder="Ej: Diego Martínez"
                  class="w-full rounded-xl px-4 py-3 outline-none transition-all text-sm"
                  style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:#e2e8f0;"
                  onfocus="this.style.borderColor='rgba(59,130,246,0.5)'; this.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)'"
                  onblur="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.boxShadow='none'" />
            </div>
            <div class="space-y-2">
                <label class="font-bold text-xs uppercase tracking-widest" style="color:#64748b;">Tipo de Servicio</label>
                <select id="q-service"
                  class="w-full rounded-xl px-4 py-3 outline-none transition-all text-sm appearance-none"
                  style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:#e2e8f0;">
                    <option value="Desarrollo Backend (Laravel)" style="background:#1e293b;">Desarrollo Backend (Laravel)</option>
                    <option value="Sistemas Node.js" style="background:#1e293b;">Sistemas en Node.js</option>
                    <option value="Arquitectura de Datos" style="background:#1e293b;">Arquitectura de Datos (BD)</option>
                    <option value="Consultoría / Implementación" style="background:#1e293b;">Consultoría de Implementación</option>
                    <option value="Otro" style="background:#1e293b;">Otro requerimiento</option>
                </select>
            </div>
          </div>
          
          <div class="space-y-2">
            <label class="font-bold text-xs uppercase tracking-widest" style="color:#64748b;">Descripción del Proyecto</label>
            <textarea id="q-details" required rows="4" placeholder="Describe brevemente lo que necesitas..."
              class="w-full rounded-xl px-4 py-3 outline-none transition-all text-sm resize-none"
              style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:#e2e8f0;"
              onfocus="this.style.borderColor='rgba(59,130,246,0.5)'; this.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)'"
              onblur="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.boxShadow='none'"></textarea>
          </div>
          
          <div class="pt-4 flex flex-col sm:flex-row items-center gap-4">
              <button type="button" id="btn-whatsapp" class="w-full sm:w-1/2 text-white font-bold py-4 rounded-xl transition-colors duration-300 flex justify-center items-center gap-2" style="background:#25D366; box-shadow:0 4px 20px rgba(37,211,102,0.25);">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.898-4.45 9.898-9.896 0-2.679-1.044-5.198-2.939-7.093-1.894-1.895-4.414-2.94-7.09-2.94-5.45 0-9.899 4.45-9.899 9.896 0 1.712.445 3.292 1.328 4.782l-1.151 4.205 4.461-1.15zM17.476 14.51c-.244-.122-1.446-.714-1.669-.796-.223-.082-.385-.122-.547.122-.162.244-.649.796-.798.96-.149.162-.298.183-.542.061-1.353-.668-2.607-1.498-3.702-2.457-.831-.727-1.49-1.598-1.954-2.559-.112-.23.014-.356.136-.477.109-.108.244-.285.366-.427.122-.142.162-.244.244-.407.082-.162.041-.305-.02-.427-.061-.122-.547-1.321-.749-1.808-.2-.477-.404-.412-.547-.42-.142-.007-.305-.007-.468-.007-.162 0-.427.061-.649.305-.224.244-.852.833-.852 2.035 0 1.201.872 2.364.994 2.527.122.162 1.725 2.631 4.18 3.633 1.944.793 2.583.743 3.19.689.654-.058 1.446-.591 1.648-1.163.203-.571.203-1.059.142-1.163-.061-.104-.224-.165-.468-.287z"/></svg>
                  <span>Cotizar Vía WhatsApp</span>
              </button>
              
              <button type="submit" id="btn-email" class="w-full sm:w-1/2 text-white font-bold py-4 rounded-xl transition-all duration-300 flex justify-center items-center gap-2" style="background:rgba(59,130,246,0.15); border:1px solid rgba(59,130,246,0.3);" onmouseover="this.style.background='#3b82f6'" onmouseout="this.style.background='rgba(59,130,246,0.15)'">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                  <span>Enviar por Correo</span>
              </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>


<script>
  // WHATSAPP QUOTE LOGIC (V20 - Native JS ONLY)
  const wppBtn = document.getElementById('btn-whatsapp');
  wppBtn?.addEventListener('click', () => {
      // 1. Obtener valores
      const name = (document.getElementById('q-name') as HTMLInputElement).value;
      const service = (document.getElementById('q-service') as HTMLSelectElement).value;
      const details = (document.getElementById('q-details') as HTMLTextAreaElement).value;

      // 2. Construir mensaje
      if(!name || !details) {
          alert("Por favor llena tu nombre y los detalles del proyecto para cotizar vía WhatsApp.");
          return;
      }

      const phoneNumber = '573000000000'; // REPLACE THIS WITH USER'S REAL NUMBER
      const message = `Hola Juan Esteban, soy *${name}*.\n\nMe interesa cotizar el servicio de: *${service}*\n\n*Detalles del proyecto:*\n${details}`;
      const encodedMessage = encodeURIComponent(message);
      
      const whatsappURL = `https://wa.me/${phoneNumber}?text=${encodedMessage}`;
      window.open(whatsappURL, '_blank');
  });

  // EMAIL QUOTE LOGIC
  const emailForm = document.getElementById('quote-form-v18');
  emailForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('q-name') as HTMLInputElement).value;
      const service = (document.getElementById('q-service') as HTMLSelectElement).value;
      const details = (document.getElementById('q-details') as HTMLTextAreaElement).value;

      const subject = `Nueva Cotización: ${service} - ${name}`;
      const body = `Nombre: ${name}\nServicio: ${service}\n\nDetalles:\n${details}`;
      
      const mailtoURL = `mailto:hola@juanesteban.dev?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = mailtoURL;
  });

</script>
