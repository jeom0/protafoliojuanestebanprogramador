<section id="about" class="py-32 px-6 md:px-12 bg-white relative z-10 min-h-screen flex flex-col justify-center items-center">
  <div class="max-w-6xl mx-auto text-center w-full">
    
    <p class="font-sans text-xs font-bold uppercase tracking-widest text-black mb-12">SOBRE MÍ</p>
    
    <h2 data-gsap="about-reveal" class="text-[8vw] sm:text-[6vw] md:text-[80px] lg:text-[100px] font-heading font-black leading-[0.9] text-black/20 uppercase tracking-tighter w-full">
      INGENIERO BACKEND.<br/>
      EXPERTO EN N8N.<br/>
      RESOLVEDOR DE<br/>
      PROBLEMAS DÍFICILES.
    </h2>

  </div>
</section>

<style is:global>
  [data-gsap="about-reveal"] .word {
      background: linear-gradient(to right, #000 50%, rgba(0,0,0,0.15) 50%);
      background-size: 200% 100%;
      background-position: 100% 0;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import SplitType from 'split-type';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
      const aboutText = document.querySelector('[data-gsap="about-reveal"]');
      if (aboutText) {
          const split = new SplitType(aboutText as HTMLElement, { types: 'words' });
          
          gsap.to(split.words, {
              backgroundPosition: '0% 0',
              ease: 'none',
              scrollTrigger: {
                  trigger: aboutText,
                  start: 'top 80%',
                  end: 'bottom 40%',
                  scrub: 1
              }
          });
      }
  });
</script>
