---
---
<div class="relative w-[300px] h-[400px] md:w-[450px] md:h-[550px] cyber-robot-container">
    <!-- Neon Halo (Behind Robot) -->
    <div id="cyber-halo" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] rounded-full bg-black border-[2px] border-[#00FF88] shadow-[0_0_100px_rgba(0,255,136,0.3)] opacity-80 z-0">
        <!-- Internal Halo Text Rings -->
        <div class="absolute inset-0 animate-spin-slow opacity-20">
            <svg viewBox="0 0 200 200" class="w-full h-full">
                <path id="circlePath" d="M 100, 100 m -80, 0 a 80,80 0 1,0 160,0 a 80,80 0 1,0 -160,0" fill="none" />
                <text class="fill-[#00FF88] font-mono text-[6px] uppercase tracking-widest">
                    <textPath href="#circlePath">SYSTEMS_AUTONOMOUS // PROTOCOL_V13 // CYBER_ENGINEERING //</textPath>
                </text>
            </svg>
        </div>
    </div>

    <!-- Robotic Head Compose (SVG) -->
    <svg viewBox="0 0 200 250" class="relative z-10 w-full h-full drop-shadow-[0_0_30px_rgba(0,255,136,0.1)]">
        <defs>
            <linearGradient id="metalGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#111" />
                <stop offset="50%" stop-color="#222" />
                <stop offset="100%" stop-color="#050505" />
            </linearGradient>
            <filter id="neonGlow">
                <feGaussianBlur stdDeviation="2" result="blur" />
                <feComposite in="SourceGraphic" in2="blur" operator="over" />
            </filter>
        </defs>

        <!-- Neck/Base -->
        <path d="M70,220 L130,220 L125,240 L75,240 Z" fill="#0A0A0A" stroke="#333" stroke-width="0.5" />
        
        <!-- Main Head Structure -->
        <path d="M60,80 C60,40 140,40 140,80 L140,160 C140,180 60,180 60,160 Z" fill="url(#metalGradient)" stroke="#00FF88" stroke-width="0.5" stroke-opacity="0.3" />
        
        <!-- Side Audio/Comms Modules -->
        <rect x="50" y="100" width="15" height="40" rx="4" fill="#111" stroke="#333" stroke-width="0.5" />
        <rect x="135" y="100" width="15" height="40" rx="4" fill="#111" stroke="#333" stroke-width="0.5" />
        
        <!-- Cyber Visor -->
        <path d="M65,90 L135,90 L135,115 L65,115 Z" fill="#000" stroke="#00FF88" stroke-width="1" filter="url(#neonGlow)" />
        <!-- Visor Scanning Line -->
        <line x1="68" y1="102" x2="132" y2="102" stroke="#00FF88" stroke-width="2" class="visor-scan" />
        
        <!-- Chin / Mouth Plate -->
        <path d="M85,165 L115,165 L110,185 L90,185 Z" fill="#151515" stroke="#00FF88" stroke-width="0.5" stroke-opacity="0.2" />
        
        <!-- Internal Circuitry Detail -->
        <g opacity="0.4">
            <line x1="75" y1="130" x2="125" y2="130" stroke="#00FF88" stroke-width="0.2" />
            <line x1="100" y1="130" x2="100" y2="160" stroke="#00FF88" stroke-width="0.2" />
            <circle cx="100" cy="145" r="3" fill="none" stroke="#00FF88" stroke-width="0.2" />
        </g>
    </svg>
    
    <!-- Floating Tech Bits -->
    <div class="absolute top-10 right-0 w-12 h-12 border border-[#00FF88]/20 rounded-sm animate-float"></div>
    <div class="absolute bottom-20 left-0 w-8 h-8 border border-[#00FF88]/20 rotate-45 animate-float-delayed"></div>
</div>

<style>
    .cyber-robot-container {
        perspective: 1000px;
    }

    .visor-scan {
        stroke-dasharray: 4, 100;
        animation: scan 2s linear infinite;
    }

    @keyframes scan {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(200%); }
    }

    .animate-spin-slow {
        animation: spin 30s linear infinite;
    }

    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .animate-float {
        animation: float 4s ease-in-out infinite;
    }
    .animate-float-delayed {
        animation: float 5s ease-in-out infinite 1s;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }
</style>
