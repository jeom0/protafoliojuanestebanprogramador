---
interface Props {
  title: string;
  tags: string[];
  url: string;
  year: string;
  image: string;
  index: number;
}

const { title, tags, url, year, image, index } = Astro.props;
---

<div class="work-item group border-t border-white/10 py-12 md:py-24 flex flex-col md:flex-row md:items-center justify-between gap-8 relative overflow-visible reveal-work">
  <div class="z-10 flex-1">
    <div class="flex items-center gap-6 mb-6">
      <span class="text-[10px] font-mono text-[rgba(243,244,246,0.2)] tracking-[0.2em]">0{(index + 1)} — {year}</span>
      <div class="flex gap-3">
        {tags.map(tag => (
          <span class="text-[9px] font-mono border border-white/10 px-2.5 py-1 uppercase tracking-wider text-[rgba(243,244,246,0.4)] transition-colors group-hover:border-[#00FF88]/30 group-hover:text-[#00FF88]/80">{tag}</span>
        ))}
      </div>
    </div>
    <a href={url} class="block">
      <h3 class="text-4xl md:text-8xl font-heading font-bold uppercase tracking-tighter group-hover:text-[#00FF88] transition-colors duration-700 leading-none">{title}</h3>
    </a>
  </div>

  <div class="md:text-right z-10">
    <a href={url} aria-label={`View ${title}`} class="inline-flex items-center justify-center w-14 h-14 md:w-20 md:h-20 border border-white/10 rounded-full hover:bg-white hover:text-[#0B0D10] transition-all duration-700">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8 rotate-[-45deg] group-hover:rotate-0 transition-transform duration-700">
        <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <!-- Work Preview Image -->
  <div class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[40vw] max-w-xl aspect-[16/10] rounded-sm overflow-hidden pointer-events-none opacity-0 scale-90 transition-all duration-700 ease-[cubic-bezier(0.19,1,0.22,1)] z-40 group-hover:opacity-100 group-hover:scale-100 hidden lg:block">
    <img src={image} alt={title} class="w-full h-full object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-1000" />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0B0D10]/50 to-transparent"></div>
  </div>
</div>
