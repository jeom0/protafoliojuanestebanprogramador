---
const steps = [
  { 
    num: "01", 
    title: "Requerimientos", 
    desc: "Análisis técnico y definición de objetivos.",
    details: ["Auditoría de infraestructura", "Selección de stack tecnológico", "Definición de requerimientos"],
    duration: "1 Semanas",
    color: "bg-blue-600"
  },
  { 
    num: "02", 
    title: "Arquitectura", 
    desc: "Diseño sistémico y estructural.",
    details: ["Modelado de Bases de Datos", "Diagramas de arquitectura", "Diseño de APIs (Laravel/Node)"],
    duration: "2 Semanas",
    color: "bg-indigo-600"
  },
  { 
    num: "03", 
    title: "Construcción", 
    desc: "Desarrollo técnico de alto nivel.",
    details: ["Implementación Frontend & Backend", "Integración de servicios", "Unit Testing & QA"],
    duration: "4-8 Semanas",
    color: "bg-blue-700"
  },
  { 
    num: "04", 
    title: "Despliegue", 
    desc: "Lanzamiento y mantenimiento.",
    details: ["Implementación en Servidores", "Optimización de rendimiento", "Soporte y Asesoría continua"],
    duration: "1-2 Semanas",
    color: "bg-indigo-700"
  }
];
---

<section id="proceso" class="py-24 relative overflow-hidden border-t" style="border-color:rgba(255,255,255,0.06);">
  <div class="container mx-auto px-6 relative z-10 w-full">
    
    <!-- HEADER -->
    <div class="flex flex-col items-center lg:items-start mb-20 reveal-on-scroll">
        <span class="px-5 py-2 rounded-full text-[10px] font-black tracking-widest uppercase mb-8 inline-block border shadow-sm" style="background:rgba(59,130,246,0.1); color:#93c5fd; border-color:rgba(59,130,246,0.2);">
            Ecosistema de Trabajo
        </span>
        <h2 class="font-heading text-4xl sm:text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.85] font-black pb-2 break-words" style="color:#f1f5f9;">
            METODOLOGÍA <br class="sm:hidden" /> <span class="text-blue-500 italic drop-shadow-2xl">DE TRABAJO.</span>
        </h2>
    </div>

    <!-- LIQUID CARDS GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {steps.map((step, index) => (
        <div class="liquid-card group relative rounded-[2.5rem] overflow-hidden transition-all duration-500 reveal-on-scroll p-1 w-full h-[400px] cursor-default"
             style={`transition-delay: ${index * 100}ms; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07);`}>
          
          <!-- Liquid Fill Droplet -->
          <div class={`absolute -top-10 left-1/2 -translate-x-1/2 w-4 h-4 rounded-full ${step.color} scale-0 group-hover:scale-[300] transition-transform duration-700 ease-in-out pointer-events-none z-10 opacity-0 group-hover:opacity-100 origin-center`}></div>
          
          <!-- Inner Card Content (dark glass default, transparent on hover) -->
          <div class="relative z-20 w-full h-full rounded-[2.3rem] p-10 flex flex-col justify-between overflow-hidden transition-colors duration-500" style="background:rgba(255,255,255,0.02);">
            
            <!-- Default View -->
            <div class="front-content group-hover:opacity-0 group-hover:-translate-y-4 transition-all duration-500">
               <span class="font-mono text-5xl font-black block mb-6" style="color:rgba(255,255,255,0.07);">{step.num}</span>
               <h3 class="text-3xl font-black mb-4 tracking-tighter leading-tight" style="color:#f1f5f9;">
                   {step.title}
               </h3>
               <p class="text-sm leading-relaxed font-medium tracking-tight" style="color:#475569;">
                   {step.desc}
               </p>
            </div>

            <!-- Hover Reveal Content -->
            <div class="absolute inset-x-10 top-10 pointer-events-none opacity-0 group-hover:opacity-100 group-hover:translate-y-0 translate-y-8 transition-all duration-700 delay-100 text-white flex flex-col h-[80%] justify-between z-30">
                <div>
                   <span class="font-mono text-xs font-black tracking-widest uppercase mb-6 block" style="color:rgba(255,255,255,0.5);">FASE_{step.num}</span>
                   <h3 class="text-2xl font-black mb-6 tracking-tighter text-white">{step.title}</h3>
                   
                   <ul class="space-y-3">
                      {step.details.map(detail => (
                        <li class="text-[11px] font-bold flex items-center gap-2 tracking-tight text-white">
                           <span class="w-1.5 h-1.5 bg-white rounded-full opacity-60"></span>
                           {detail}
                        </li>
                      ))}
                   </ul>
                </div>

                <div class="pt-6" style="border-top:1px solid rgba(255,255,255,0.2);">
                   <p class="font-mono text-[9px] uppercase tracking-[2px] mb-2" style="color:rgba(255,255,255,0.5);">Tiempo Estimado:</p>
                   <p class="text-xl font-black italic text-white">{step.duration}</p>
                </div>
            </div>

            <!-- Bottom Arrow Indicator -->
            <div class="relative z-30 flex justify-end group-hover:opacity-0 transition-opacity">
                <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08);">
                   <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:rgba(255,255,255,0.3);"><path d="M14 5l7 7m0 0l-7 7m7-7H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
            </div>

          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<style>
  /* Ensure mobile tap behavior triggers hover on devices */
  @media (hover: none) {
    .liquid-card:active .scale-0 {
      transform: scale(100);
      opacity: 1;
    }
    .liquid-card:active .bg-white {
      background-color: transparent;
    }
  }

  .liquid-card {
    /* Performance hint */
    will-change: transform;
    perspective: 1000px;
  }

  .liquid-card:hover {
    transform: translateY(-5px);
  }

  .scale-0 {
    transform: scale(0);
  }
</style>

