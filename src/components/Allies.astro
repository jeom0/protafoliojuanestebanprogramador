<section id="aliados" class="py-24 bg-white relative overflow-hidden flex flex-col items-center">
  <p class="font-sans text-[10px] md:text-xs font-bold uppercase tracking-widest text-[#0066ff] mb-12">ALIADOS E INTEGRACIONES</p>
  
  <div class="relative w-full flex overflow-hidden before:absolute before:left-0 before:top-0 before:z-10 before:h-full before:w-[150px] before:bg-gradient-to-r before:from-white before:to-transparent after:absolute after:right-0 after:top-0 after:z-10 after:h-full after:w-[150px] after:bg-gradient-to-l after:from-white after:to-transparent">
    
    <div class="flex items-center gap-16 md:gap-32 w-max animate-scroll-logos grayscale opacity-60">
      
      <!-- Logo Batch 1 -->
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">AWS</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">N8N</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">STRIPE</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">SHOPIFY</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">HUBSPOT</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">SALESFORCE</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">SLACK</div>

      <!-- Logo Batch 2 (Duplicate for infinite seamless scroll) -->
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">AWS</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">N8N</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">STRIPE</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">SHOPIFY</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">HUBSPOT</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">SALESFORCE</div>
      <div class="font-heading text-4xl md:text-5xl font-black tracking-tighter text-black">SLACK</div>

    </div>
  </div>
</section>

<style>
  @keyframes scroll-logos {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-scroll-logos {
    animation: scroll-logos 20s linear infinite;
  }
</style>
