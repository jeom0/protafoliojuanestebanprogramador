---
import { allies } from '../data/allies';
---

<section id="aliados" class="py-24 bg-transparent relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-10 w-full h-full flex flex-col justify-center text-center">
    
    <div class="mb-16 reveal-on-scroll text-center flex flex-col items-center">
        <span class="px-5 py-2 rounded-full text-[10px] font-black tracking-widest uppercase inline-block border backdrop-blur-md mb-6" style="background:rgba(59,130,246,0.1); color:#93c5fd; border-color:rgba(59,130,246,0.2);">
            Red de Confianza
        </span>
        <h2 class="font-heading text-5xl md:text-7xl tracking-tighter leading-[0.85] font-black text-transparent bg-clip-text bg-gradient-to-br from-slate-100 to-slate-400 pb-2">
            ALIADOS <span class="text-blue-500 block sm:inline drop-shadow-2xl italic">ESTRATÉGICOS.</span>
        </h2>
    </div>

    <!-- CLEAN BENTO LOGO GRID (V35 Liquid Glass) -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6 allies-grid-v19 max-w-6xl mx-auto w-full">
      {allies.map((ally, index) => (
        <div class={`bento-interactive transition-all duration-500 rounded-[2rem] p-8 flex flex-col items-center justify-center aspect-square group animate-float reveal-on-scroll delay-${(index % 6) * 100 + 100}`} 
             style={`animation-duration: ${4 + (index % 3)}s;`}>
          <img 
            src={ally.logo} 
            alt={ally.name} 
            class="w-full h-auto max-h-[60px] object-contain opacity-40 grayscale-[50%] group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 transform group-hover:scale-110 filter brightness-110 contrast-125"
          />
        </div>
      ))}
    </div>
  </div>
</section>

