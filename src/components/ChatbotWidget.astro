---
---
<div id="chat-root">

  <!-- ═══ CHAT WINDOW ═══ -->
  <div id="chat-win">
    <!-- absolute-positioned inner ensures 3-row layout always works -->
    <div id="chat-inner">

      <!-- Row 1: Header -->
      <div id="chat-head">
        <div id="chat-avatar">
          <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div id="chat-title-wrap">
          <span id="chat-title">A.I. ASSISTANT</span>
          <span id="chat-sub">Juan's Portfolio Bot · <span id="chat-status-dot">●</span> Online</span>
        </div>
        <button id="chat-close-btn" aria-label="Cerrar">✕</button>
      </div>

      <!-- Row 2: Messages -->
      <div id="chat-body">
        <div class="msg-row bot">
          <div class="msg-bubble bot">
            Hola 👋 Soy el asistente virtual de Juan Esteban. ¿En qué te puedo ayudar hoy? Puedo responderte preguntas sobre precios, tecnologías, o conectarte con Juan.
          </div>
        </div>
      </div>

      <!-- Row 3: Input -->
      <div id="chat-foot">
        <form id="chat-form">
          <input id="chat-input" type="text" placeholder="Escribe tu mensaje..." autocomplete="off" />
          <button type="submit" id="chat-send" aria-label="Enviar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </button>
        </form>
        <p id="chat-powered">Powered by Grok AI · n8n</p>
      </div>

    </div>
  </div>

  <!-- ═══ FAB BUTTON ═══ -->
  <button id="chat-fab" aria-label="Abrir chat">
    <svg id="fab-icon-msg" width="24" height="24" fill="none" stroke="white" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
    </svg>
    <svg id="fab-icon-x" width="22" height="22" fill="none" stroke="white" viewBox="0 0 24 24" style="display:none;">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

</div>

<style>
  /* ── Root ── */
  #chat-root { position: fixed; bottom: 0; right: 0; z-index: 9999; }

  /* ── FAB ── */
  #chat-fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #000;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    transition: background 0.25s, transform 0.15s;
  }
  #chat-fab:hover { background: #0066ff; }
  #chat-fab:active { transform: scale(0.92); }

  /* ── Window ── */
  #chat-win {
    display: none;
    position: fixed;
    right: 24px;
    bottom: 88px;
    width: 360px;
    height: 520px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.18), 0 4px 20px rgba(0,0,0,0.08);
    animation: chat-pop 0.3s ease;
  }
  @keyframes chat-pop {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }
  @media(max-width: 480px) {
    #chat-win {
      /* Use inset:0 so we can control height via JS using visualViewport */
      right: 0 !important;
      bottom: 0 !important;
      left: 0 !important;
      top: 0 !important;
      width: 100% !important;
      height: 100% !important;
      border-radius: 0;
    }
  }

  /* ── Inner grid ── */
  #chat-inner {
    display: grid;
    grid-template-rows: auto 1fr auto;
    height: 100%;
    width: 100%;
    background: #f7f8fa;
  }

  /* ── Header ── */
  #chat-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: #000;
    flex-shrink: 0;
  }
  #chat-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #0066ff;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  #chat-title-wrap { flex: 1; min-width: 0; }
  #chat-title {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 12px;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  #chat-sub {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 500;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 2px;
  }
  #chat-status-dot { color: #4ade80; }
  #chat-close-btn {
    background: rgba(255,255,255,0.1);
    border: none;
    border-radius: 50%;
    width: 28px; height: 28px;
    color: white;
    font-size: 13px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  #chat-close-btn:hover { background: rgba(255,255,255,0.2); }

  /* ── Messages ── */
  #chat-body {
    overflow-y: auto;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: #f7f8fa; /* Modern light background */
  }
  .msg-row { display: flex; width: 100%; margin-bottom: 4px; }
  .msg-row.bot { justify-content: flex-start; }
  .msg-row.user { justify-content: flex-end; }
  
  .msg-bubble {
    max-width: 82%;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    padding: 12px 16px;
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
  }
  
  .msg-bubble.bot {
    background: #ffffff !important;
    color: #111 !important;
    border-radius: 16px 16px 16px 4px;
  }
  .msg-bubble.bot * {
    color: #111 !important;
  }

  .msg-bubble.user {
    background: #0066ff !important; /* Brand Blue */
    color: #ffffff !important;
    border-radius: 16px 16px 4px 16px;
  }
  .msg-bubble.user * {
    color: #ffffff !important;
  }

  .msg-bubble.typing span {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #888;
    margin: 0 2px;
    animation: blink 1.2s infinite;
  }
  .msg-bubble.typing span:nth-child(2) { animation-delay: 0.2s; }
  .msg-bubble.typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink { 0%,80%,100%{opacity:.3} 40%{opacity:1} }

  /* ── Input ── */
  #chat-foot {
    padding: 12px;
    background: #fff;
    border-top: 1px solid rgba(0,0,0,0.07);
    flex-shrink: 0;
  }
  #chat-form {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f2f3f5;
    border: 1.5px solid transparent;
    border-radius: 100px;
    padding: 6px 6px 6px 16px;
    transition: border-color 0.2s;
  }
  #chat-form:focus-within { border-color: rgba(0,102,255,0.4); }
  #chat-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #111;
    min-width: 0;
  }
  #chat-input::placeholder { color: rgba(0,0,0,0.35); }
  #chat-send {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #000;
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  #chat-send:hover { background: #0066ff; }
  #chat-powered {
    text-align: center;
    margin: 8px 0 0;
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 600;
    color: rgba(0,0,0,0.25);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  /* Action buttons inside messages */
  .msg-actions { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
  .msg-action-btn {
    padding: 6px 14px;
    border-radius: 100px;
    background: #000;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s;
  }
  .msg-action-btn:hover { background: #0066ff; }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  const fab = document.getElementById('chat-fab');
  const win = document.getElementById('chat-win');
  const closeBtn = document.getElementById('chat-close-btn');
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const body = document.getElementById('chat-body');
  const fabMsg = document.getElementById('fab-icon-msg');
  const fabX = document.getElementById('fab-icon-x');

  let isOpen = false;
  let idleTimer = null;
  let idleFired = false;

  function isMobile() { return window.innerWidth <= 480; }

  function applyViewport() {
    if (!isOpen || !isMobile()) return;
    const vv = window.visualViewport;
    if (!vv) return;
    // Position the window to start at the top of the visible area
    // and end exactly where the keyboard starts
    win.style.top = vv.offsetTop + 'px';
    win.style.height = vv.height + 'px';
  }

  function open() {
    isOpen = true;
    win.style.display = 'block';
    fabMsg.style.display = 'none';
    fabX.style.display = 'block';
    fab.style.background = '#0066ff';
    body.scrollTop = body.scrollHeight;
    setTimeout(() => input.focus(), 200);
    startIdle();
    // Mobile: listen to visualViewport so the keyboard doesn't push the input
    if (isMobile() && window.visualViewport) {
      applyViewport();
      window.visualViewport.addEventListener('resize', applyViewport);
      window.visualViewport.addEventListener('scroll', applyViewport);
      document.body.style.overflow = 'hidden';
    }
  }

  function close() {
    isOpen = false;
    win.style.display = 'none';
    fabX.style.display = 'none';
    fabMsg.style.display = 'block';
    fab.style.background = '#000';
    // Clean up mobile listeners
    if (window.visualViewport) {
      window.visualViewport.removeEventListener('resize', applyViewport);
      window.visualViewport.removeEventListener('scroll', applyViewport);
    }
    document.body.style.overflow = '';
    // Reset mobile inline styles
    if (isMobile()) { win.style.top = ''; win.style.height = ''; }
  }

  function startIdle() {
    clearTimeout(idleTimer);
    if (idleFired) return;
    idleTimer = setTimeout(() => {
      if (!isOpen || idleFired) return;
      idleFired = true;
      addBot('Parece que llevas un rato sin escribir 👋 Voy a cerrar el chat por ahora. Si necesitas algo, estaré aquí.', []);
      setTimeout(() => {
        close();
      }, 3000); // Close automatically after 3 seconds
    }, 300000); // 5 minutes = 300,000 ms
  }

  function sendSurvey() {
    addBot('¡Hola de nuevo! Antes de continuar, ¿qué tal te ha parecido la experiencia usando este chatbot?', [
      { label: 'Excelente 🤩', href: '#' },
      { label: 'Normal 👍', href: '#' },
      { label: 'Podría mejorar 🤔', href: '#' }
    ]);
  }

  fab.addEventListener('click', () => {
    if (isOpen) {
      close();
    } else {
      open();
      if (idleFired) {
        // If they return after being idled out, ask for feedback
        idleFired = false; 
        setTimeout(sendSurvey, 500);
      }
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    clearTimeout(idleTimer);
    startIdle();
    addUser(text);
    input.value = '';
    const lc = text.toLowerCase();

    // Contact intent
    if (lc.match(/humano|asesor|contacto|persona|hablar|juan/)) {
      setTimeout(() => addBot('¡Claro! Aquí puedes comunicarte directamente con Juan:', [
        { label: 'WhatsApp', href: 'https://wa.me/573245638720' },
        { label: 'Correo', href: 'mailto:jeom.245@gmail.com' },
      ]), 700);
      return;
    }

    // Show typing
    const typingId = addTyping();

    try {
      const res = await fetch('https://tu-dominio-n8n.com/webhook/portfolio-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text }),
      });
      removeTyping(typingId);
      if (!res.ok) throw new Error();
      const data = await res.json();
      addBot(data.reply || 'No pude procesar esa respuesta.');
    } catch {
      removeTyping(typingId);
      let reply = 'Puedo ayudarte con información sobre mis servicios y proyectos. ¿Qué necesitas?';
      if (lc.match(/precio|costo|cotiz|cuanto/)) {
        reply = 'Aquí mis tarifas 👇\n\n• Landing Page: $700k COP\n• Sitio 3 secciones: $1.4M COP\n• Sitio Pro + CMS: $2.5M COP\n• Web Empresarial: $2M–$3.8M COP\n• App Móvil: Desde $4M COP\n• Asesoría: $250k/sesión\n\n¿Cuál se adapta a tu proyecto?';
      } else if (lc.match(/hola|buenos|buenas|hey/)) {
        reply = '¡Hola! 👋 ¿En qué puedo ayudarte hoy?';
      } else if (lc.match(/tecnolog|stack|length|back/)) {
        reply = 'Trabajo con Node.js, Laravel (PHP), Python, AWS, Docker y n8n para automatizaciones. ¿Tienes alguna duda específica?';
      } else if (lc.match(/proyecto|portaf|trabajo/)) {
        reply = 'Puedes ver mis proyectos en la sección WORK de esta página. Incluyen sistemas backend, automatizaciones n8n y portales web completos. ¿Alguno te interesa?';
      }
      setTimeout(() => addBot(reply), 500);
    }
  });

  function addUser(text) {
    const row = document.createElement('div');
    row.className = 'msg-row user';
    row.innerHTML = `<div class="msg-bubble user">${esc(text)}</div>`;
    body.appendChild(row);
    body.scrollTop = body.scrollHeight;
  }

  function addBot(text, actions = []) {
    const row = document.createElement('div');
    row.className = 'msg-row bot';
    let actionsHtml = '';
    if (actions.length) {
      // Changed to buttons if href is '#', else links
      actionsHtml = '<div class="msg-actions">' +
        actions.map(a => {
          if (a.href === '#') return `<button type="button" class="msg-action-btn survey-btn">${a.label}</button>`;
          return `<a href="${a.href}" target="_blank" class="msg-action-btn">${a.label}</a>`;
        }).join('') +
        '</div>';
    }
    const html = esc(text).replace(/\n/g, '<br>');
    row.innerHTML = `<div class="msg-bubble bot">${html}${actionsHtml}</div>`;
    body.appendChild(row);
    body.scrollTop = body.scrollHeight;

    // Attach survey button logic
    row.querySelectorAll('.survey-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const val = e.target.innerText;
        addUser(val);
        setTimeout(() => addBot('¡Gracias por tu feedback! 🙌 ¿En qué más te puedo ayudar hoy?'), 600);
        // Disable buttons after click
        row.querySelectorAll('.survey-btn').forEach(b => {
           b.style.pointerEvents = 'none';
           b.style.opacity = '0.5';
        });
      });
    });
  }

  function addTyping() {
    const id = 'typing-' + Date.now();
    const row = document.createElement('div');
    row.className = 'msg-row bot';
    row.id = id;
    row.innerHTML = '<div class="msg-bubble bot typing"><span></span><span></span><span></span></div>';
    body.appendChild(row);
    body.scrollTop = body.scrollHeight;
    return id;
  }

  function removeTyping(id) {
    document.getElementById(id)?.remove();
  }

  function esc(t) {
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
});
</script>
