---
---
<div id="chatbot-container" class="fixed bottom-6 right-6 z-[200] font-sans flex flex-col items-end">
    
    <!-- Floating Button -->
    <button id="chatbot-toggle" class="w-16 h-16 rounded-full bg-black shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] flex items-center justify-center text-white hover:scale-110 active:scale-95 transition-all duration-300 relative group border border-white/20">
        <!-- Ping Animation -->
        <span class="absolute inset-0 rounded-full border border-black animate-ping opacity-20"></span>
        
        <!-- Icons -->
        <svg id="icon-chat" class="w-7 h-7 absolute transition-all duration-300 transform scale-100 rotate-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
        <svg id="icon-close" class="w-7 h-7 absolute transition-all duration-300 transform scale-0 -rotate-90 opacity-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <!-- Chat Window Content -->
    <div id="chatbot-window" class="hidden flex-col w-[92vw] sm:w-[380px] h-[75vh] sm:h-[600px] max-h-[800px] bg-[#F2F2F2]/95 backdrop-blur-2xl rounded-3xl border border-black/10 shadow-[0_20px_60px_rgba(0,0,0,0.15)] mb-4 overflow-hidden transform origin-bottom-right transition-all duration-500 scale-95 opacity-0 absolute bottom-16 right-0 sm:right-auto">
        
        <!-- Chat Header -->
        <div class="px-6 py-5 border-b border-black/5 flex items-center gap-4 relative overflow-hidden bg-white/50">
            <!-- decorative gradient -->
            <div class="absolute top-0 right-0 w-32 h-32 bg-[#0066ff] rounded-full blur-3xl opacity-10 translate-x-1/2 -translate-y-1/2"></div>
            
            <div class="relative">
                <div class="w-12 h-12 rounded-full bg-black flex items-center justify-center border-2 border-white shadow-lg overflow-hidden p-2">
                    <svg class="w-full h-full text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <div class="absolute bottom-0 right-0 w-3.5 h-3.5 bg-green-500 rounded-full border-2 border-white z-10"></div>
            </div>
            
            <div class="relative z-10">
                <h3 class="font-heading font-black text-xl text-black leading-none uppercase tracking-tighter mix-blend-multiply">A.I. Assistant</h3>
                <p class="text-[10px] font-sans font-bold text-black/40 uppercase tracking-widest mt-1">Juan's Portfolio Bot</p>
            </div>
        </div>

        <!-- Chat Output Area -->
        <div id="chatbot-messages" class="flex-1 p-6 overflow-y-auto flex flex-col gap-4 scroll-smooth">
            <!-- Initial Welcome Message -->
            <div class="flex flex-col gap-1 items-start w-5/6">
                <span class="text-[9px] font-sans font-bold text-black/30 uppercase tracking-[0.2em] ml-2">Asistente A.I.</span>
                <div class="bg-white text-black text-sm font-sans font-medium p-4 rounded-2xl rounded-tl-sm shadow-sm border border-black/5 leading-relaxed">
                    Hola. Soy el asistente virtual de Juan Esteban. ¿Necesitas una cotización para una arquitectura backend o automatización en n8n?
                </div>
            </div>
        </div>

        <!-- Chat Input Area -->
        <div class="p-4 border-t border-black/5 bg-white">
            <form id="chatbot-form" class="relative group">
                <input 
                    type="text" 
                    id="chatbot-input" 
                    class="w-full bg-[#F2F2F2] border border-black/10 text-black text-[16px] placeholder-black/30 rounded-full py-4 pl-6 pr-14 focus:outline-none focus:border-[#0066ff]/50 focus:ring-1 focus:ring-[#0066ff]/50 transition-all font-sans font-medium"
                    placeholder="Escribe tu mensaje..."
                    autocomplete="off"
                />
                <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black text-white flex items-center justify-center hover:bg-[#0066ff] hover:scale-105 active:scale-95 transition-all shadow-md">
                    <svg class="w-4 h-4 translate-x-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"></path></svg>
                </button>
            </form>
            <div class="text-center mt-3">
                <span class="text-[9px] font-sans font-bold text-black/20 uppercase tracking-widest flex items-center justify-center gap-1">
                    Powered by <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM11 19.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.22.23-1.8l6.77 6.77v2.96zm8.77-4.13l-6.77-6.77V6.07c3.95.49 7 3.85 7 7.93 0 .62-.08 1.22-.23 1.8z"/></svg> n8n
                </span>
            </div>
        </div>
    </div>

    <!-- Fix Mobile Safari Auto-Zoom on inputs by forcing 16px font-size -->
    <style is:global>
        #chatbot-window input[type="text"],
        #chatbot-window textarea {
            font-size: 16px !important; 
        }
    </style>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('chatbot-toggle');
    const windowEl = document.getElementById('chatbot-window');
    const iconChat = document.getElementById('icon-chat');
    const iconClose = document.getElementById('icon-close');
    const form = document.getElementById('chatbot-form');
    const input = document.getElementById('chatbot-input');
    const messagesContainer = document.getElementById('chatbot-messages');
    
    let isOpen = false;

    // Toggle logic
    toggleBtn.addEventListener('click', () => {
        isOpen = !isOpen;
        if(isOpen) {
            windowEl.classList.remove('hidden');
            // Small delay to allow display block to apply before animating opacity/scale
            setTimeout(() => {
                windowEl.classList.remove('opacity-0', 'scale-95');
                windowEl.classList.add('opacity-100', 'scale-100');
            }, 10);
            iconChat.classList.add('scale-0', '-rotate-90', 'opacity-0');
            iconClose.classList.remove('scale-0', '-rotate-90', 'opacity-0');
            iconClose.classList.add('scale-100', 'rotate-0', 'opacity-100');
            input.focus();
        } else {
            windowEl.classList.remove('opacity-100', 'scale-100');
            windowEl.classList.add('opacity-0', 'scale-95');
            setTimeout(() => {
                windowEl.classList.add('hidden');
            }, 500); // Wait for transition
            iconClose.classList.add('scale-0', '-rotate-90', 'opacity-0');
            iconChat.classList.remove('scale-0', '-rotate-90', 'opacity-0');
            iconChat.classList.add('scale-100', 'rotate-0', 'opacity-100');
        }
    });

    // Handle Form Submit
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const text = input.value.trim();
        if(!text) return;

        // 1. Add User Message to UI
        appendMessage(text, true);
        input.value = '';

        // 2. Add "Typing..." Indicator
        const typingIndicator = document.createElement('div');
        typingIndicator.className = 'flex flex-col gap-1 items-start w-5/6 animate-pulse';
        typingIndicator.innerHTML = `
            <span class="text-[9px] font-sans font-bold text-black/30 uppercase tracking-[0.2em] ml-2">Escribiendo...</span>
            <div class="bg-white border text-black/5 p-4 rounded-2xl rounded-tl-sm flex gap-1 items-center shadow-sm">
                <span class="w-2 h-2 rounded-full bg-[#0066ff]/50 animate-bounce"></span>
                <span class="w-2 h-2 rounded-full bg-[#0066ff]/50 animate-bounce" style="animation-delay: 0.1s"></span>
                <span class="w-2 h-2 rounded-full bg-[#0066ff]/50 animate-bounce" style="animation-delay: 0.2s"></span>
            </div>
        `;
        messagesContainer.appendChild(typingIndicator);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;

        try {
            // Ensure to replace this with the Production Webhook URL from n8n 
            const N8N_WEBHOOK_URL = 'https://tu-dominio-n8n.com/webhook/PORTFOLIO-AI-WEBHOOK';

            const response = await fetch(N8N_WEBHOOK_URL, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ message: text }),
            });

            if (!response.ok) throw new Error('Network response was not ok');

            const data = await response.json();
            
            // Matches the "Format Response" node from n8n-chatbot-workflow.json
            const botReply = data.reply || (Array.isArray(data) && data[0]?.reply) || "Ups, el bot n8n no devolvió el formato esperado ('reply').";
            
            typingIndicator.remove();
            appendMessage(botReply, false);

        } catch (error) {
            console.error('N8n interaction failed or not configured. Using intelligent native fallback:', error);
            typingIndicator.remove();
            
            // Intelligent Fallback Logic (Mock AI)
            const inputLower = text.toLowerCase();
            let mockReply = '';
            
            if(inputLower.includes('precio') || inputLower.includes('cotiza') || inputLower.includes('costo') || inputLower.includes('cuanto')) {
                mockReply = '¡Claro! Los proyectos de arquitectura backend o desarrollo full-stack varían según el alcance. Por favor escríbeme a juanospina@example.com o usa el botón de WhatsApp al final de la página para darte un presupuesto exacto.';
            } else if (inputLower.includes('tecnologia') || inputLower.includes('stack') || inputLower.includes('sabe') || inputLower.includes('experiencia')) {
                mockReply = 'Soy experto en construir arquitecturas escalables usando Node.js, Python, bases de datos SQL/NoSQL, y despliegues en AWS y Docker. Además, creo automatizaciones muy avanzadas en n8n.';
            } else if (inputLower.includes('hola') || inputLower.includes('buenos') || inputLower.includes('buenas') || inputLower.includes('saludos')) {
                mockReply = '¡Hola de nuevo! ¿En qué puedo ayudarte hoy? ¿Te gustaría ver los proyectos o saber más sobre mis tecnologías base?';
            } else if (inputLower.includes('contacto') || inputLower.includes('hablar') || inputLower.includes('whatsapp') || inputLower.includes('correo')) {
                mockReply = 'Puedes contactar directamente a Juan Esteban deslizando hasta el pie de página. Allí encontrarás el botón directo a mi WhatsApp personal y mi correo electrónico.';
            } else {
                mockReply = 'Entiendo. Como el asistente virtual A.I. de Juan Esteban, te recomiendo contactarle directamente vía correo o WhatsApp (abajo de la página) para hablar más a fondo sobre tu solicitud. ¡Estará encantado de ayudarte!';
            }

            // Simulate slight AI thinking delay
            setTimeout(() => {
                appendMessage(mockReply, false);
            }, 600);
        }
    });

    function appendMessage(text, isUser) {
        const msgDiv = document.createElement('div');
        msgDiv.className = `flex flex-col gap-1 w-5/6 ${isUser ? 'items-end self-end' : 'items-start'}`;
        
        const label = isUser ? 'Tú' : 'Asistente A.I.';
        const bubbleStyle = isUser 
            ? 'bg-black text-white rounded-tr-sm shadow-xl' 
            : 'bg-white text-black border border-black/5 rounded-tl-sm shadow-sm';

        msgDiv.innerHTML = `
            <span class="text-[9px] font-sans font-bold text-black/30 uppercase tracking-[0.2em] px-2">${label}</span>
            <div class="text-sm font-sans font-medium p-4 rounded-2xl ${bubbleStyle} leading-relaxed">
                ${text.replace(/\n/g, '<br>')}
            </div>
        `;
        
        messagesContainer.appendChild(msgDiv);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }
  });
</script>
