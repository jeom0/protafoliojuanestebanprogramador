---
const services = [
  { title: "BACKEND DEVELOPMENT", info: "Laravel & Node.js" },
  { title: "SYSTEM ARCHITECTURE", info: "Data & Scaling" },
  { title: "N8N AUTOMATION", info: "Workflow Design" },
  { title: "API INTEGRATION", info: "RESTful & Webhooks" }
];
---

<section id="servicios" class="py-32 relative z-10 w-full bg-[#F2F2F2]">
  <div class="container mx-auto px-4 md:px-8 max-w-[1400px]">
    
    <!-- About Paragraph (DiegoLiv Style) -->
    <div class="mb-32 max-w-5xl">
        <p class="font-heading text-[6vw] md:text-[5vw] leading-[0.9] text-black uppercase tracking-tighter">
            SOY JUAN ESTEBAN OSPINA, INGENIERO DE SOFTWARE ESPECIALIZADO EN LA 
            <span class="text-black/40 italic mix-blend-multiply">CREACIÓN DE ARQUITECTURAS BACKEND ROBUSTAS</span> 
            Y FLUJOS DE AUTOMATIZACIÓN AVANZADOS.
        </p>
        <div class="mt-12 flex gap-4">
            <span class="px-6 py-3 rounded-full border border-black/10 text-black font-sans text-xs uppercase font-bold tracking-widest bg-white">MEDELLÍN, COLOMBIA</span>
            <span class="px-6 py-3 rounded-full border border-black/10 text-black font-sans text-xs uppercase font-bold tracking-widest bg-white">AVAILABLE FOR WORK</span>
        </div>
    </div>

    <!-- Services List -->
    <div class="w-full border-t border-black/10 pt-16">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8">
            <h2 class="font-heading text-5xl md:text-7xl uppercase font-black text-black tracking-tighter leading-none">
                MIS ESPECIALIDADES.
            </h2>
            <p class="font-sans text-lg text-black/60 font-medium max-w-sm">
                Soluciones técnicas enfocadas en escalabilidad, rendimiento y optimización de datos para empresas modernas.
            </p>
        </div>

        <div class="w-full flex flex-col group/list">
            {services.map((service) => (
                <div class="group/item flex flex-col md:flex-row justify-between items-start md:items-center py-10 md:py-16 border-b border-black/10 transition-colors duration-500 hover:bg-white cursor-pointer px-4 -mx-4">
                    <h3 class="font-heading text-4xl sm:text-6xl md:text-[8vw] uppercase font-black text-black tracking-tighter leading-none transition-transform duration-500 group-hover/item:translate-x-4 mix-blend-multiply group-hover/item:text-[#0066ff]">
                        {service.title}
                    </h3>
                    <div class="mt-4 md:mt-0 font-sans text-sm md:text-base text-black/40 uppercase font-bold tracking-widest opacity-0 group-hover/item:opacity-100 transition-opacity duration-500 -translate-x-4 group-hover/item:translate-x-0">
                        {service.info}
                    </div>
                </div>
            ))}
        </div>
    </div>

  </div>
</section>
