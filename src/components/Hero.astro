---
import { siteData } from '../data/site';
---

<section id="inicio" class="relative min-h-[95vh] flex flex-col justify-center items-center pt-40 pb-0 px-4 md:px-8 bg-white overflow-hidden">
    
    <!-- Interactive Node Canvas Background -->
    <div class="absolute inset-0 w-full h-full bg-[#f8fafc] z-0 overflow-hidden">
        <canvas id="hero-particles" data-gsap="parallax-hero" class="w-full h-full pointer-events-none opacity-60"></canvas>
    </div>

    <!-- Massive Centered Typography -->
    <div class="w-full max-w-6xl mx-auto text-center relative z-10 flex flex-col items-center flex-1 justify-center">
        
        <!-- Huge Headline -->
        <h1 data-gsap="hero-title" class="font-heading text-[12vw] sm:text-[10vw] md:text-[8vw] lg:text-[110px] leading-[0.9] tracking-tighter text-black w-full uppercase font-black">
            ARQUITECTURA BACKEND<br/>
            PARA STARTUPS CONSTRUYENDO<br/>
            EL FUTURO.
        </h1>
        
        <!-- Tech Logos Sub-section -->
        <div data-gsap="hero-logos" class="w-full max-w-5xl mx-auto mt-20 md:mt-24 flex flex-wrap justify-center items-center gap-6 md:gap-12 opacity-0 -translate-y-4">
            <div class="font-heading text-xl md:text-3xl font-black text-black/60 tracking-tighter hover:text-black transition-colors">NODE.JS</div>
            <div class="font-heading text-xl md:text-3xl font-black text-black/60 tracking-tighter hover:text-black transition-colors">PYTHON</div>
            <div class="font-heading text-xl md:text-3xl font-black text-black/60 tracking-tighter hover:text-black transition-colors">N8N</div>
            <div class="font-heading text-xl md:text-3xl font-black text-black/60 tracking-tighter hover:text-black transition-colors">DOCKER</div>
            <div class="font-heading text-xl md:text-3xl font-black text-black/60 tracking-tighter hover:text-black transition-colors">AWS</div>
            <div class="font-heading text-xl md:text-3xl font-black text-black/60 tracking-tighter hover:text-black transition-colors">POSTGRESQL</div>
        </div>
    </div>

    <!-- Attached Bottom Button -->
    <div class="relative z-20 mt-20 flex justify-center w-full translate-y-1/2">
        <a href="#contacto" class="bg-black text-white px-8 py-4 font-sans text-sm font-bold uppercase tracking-widest hover:bg-[#0066ff] transition-colors shadow-2xl relative z-30 flex items-center gap-3">
            TRABAJAR CONMIGO
        </a>
    </div>

</section>

<style is:global>
    /* Prevent FOUC on split text */
    [data-gsap="hero-title"] .line {
        overflow: hidden;
    }
    [data-gsap="hero-title"] .word {
        transform: translateY(110%);
        opacity: 0;
    }
</style>

<script>
    import gsap from 'gsap';
    import SplitType from 'split-type';

    // Wait for the DOM to be fully loaded
    document.addEventListener("DOMContentLoaded", () => {
        const titleElements = document.querySelectorAll('[data-gsap="hero-title"]');
        if (titleElements.length === 0) return;

        // Reset visibility so GSAP can take over
        gsap.set('[data-gsap="hero-title"]', { opacity: 1 });
        
        // Split the text into lines and words
        const split = new SplitType('[data-gsap="hero-title"]', { types: 'lines, words' });

        // The master timeline (Diegoliv staggered entry)
        const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

        tl.to(split.words, {
            y: '0%',
            opacity: 1,
            duration: 1.2,
            stagger: 0.05,
            delay: 0.2
        })
        .to('[data-gsap="hero-logos"]', {
            opacity: 1,
            y: 0,
            duration: 1,
            ease: 'power3.out'
        }, "-=0.6");

        // Parallax Effect for Background
        gsap.to('[data-gsap="parallax-hero"]', {
            yPercent: 30,
            ease: "none",
            scrollTrigger: {
                trigger: "#inicio",
                start: "top top",
                end: "bottom top",
                scrub: true
            }
        });

        // Interactive Canvas Nodes Logic
        const canvas = document.getElementById('hero-particles') as HTMLCanvasElement;
        if(canvas) {
            const ctx = canvas.getContext('2d');
            let particles: Particle[] = [];
            
            const resize = () => {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            };
            window.addEventListener('resize', resize);
            resize();

            let mouse = { x: canvas.width / 2, y: canvas.height / 2 };
            window.addEventListener('mousemove', (e) => {
                mouse.x = e.clientX;
                mouse.y = e.clientY + window.scrollY; // adjust for scroll
            });

            class Particle {
                x: number;
                y: number;
                size: number;
                baseX: number;
                baseY: number;
                density: number;
                color: string;

                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.baseX = this.x;
                    this.baseY = this.y;
                    this.density = (Math.random() * 30) + 1;
                    this.size = Math.random() * 2 + 1;
                    this.color = Math.random() > 0.5 ? 'rgba(0, 102, 255, 0.4)' : 'rgba(0, 0, 0, 0.2)';
                }

                draw() {
                    if(!ctx) return;
                    ctx.fillStyle = this.color;
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.closePath();
                    ctx.fill();
                }

                update() {
                    const bounds = canvas.getBoundingClientRect();
                    const localMouseY = mouse.y - bounds.top;

                    let dx = mouse.x - this.x;
                    let dy = localMouseY - this.y;
                    let distance = Math.sqrt(dx * dx + dy * dy);
                    let forceDirectionX = dx / distance;
                    let forceDirectionY = dy / distance;
                    let maxDistance = 150;
                    let force = (maxDistance - distance) / maxDistance;
                    let directionX = forceDirectionX * force * this.density;
                    let directionY = forceDirectionY * force * this.density;

                    if (distance < maxDistance) {
                        this.x -= directionX;
                        this.y -= directionY;
                    } else {
                        if (this.x !== this.baseX) {
                            let dx = this.x - this.baseX;
                            this.x -= dx / 10;
                        }
                        if (this.y !== this.baseY) {
                            let dy = this.y - this.baseY;
                            this.y -= dy / 10;
                        }
                    }
                }
            }

            const init = () => {
                particles = [];
                for (let i = 0; i < 150; i++) {
                    particles.push(new Particle());
                }
            };

            const animate = () => {
                ctx?.clearRect(0, 0, canvas.width, canvas.height);
                
                // Draw and Update
                for (let i = 0; i < particles.length; i++) {
                    particles[i].draw();
                    particles[i].update();
                }
                
                // Draw Connecting Lines (Node Network Effect)
                for (let a = 0; a < particles.length; a++) {
                    for (let b = a; b < particles.length; b++) {
                        let dx = particles[a].x - particles[b].x;
                        let dy = particles[a].y - particles[b].y;
                        let distance = Math.sqrt(dx * dx + dy * dy);
                        
                        if (distance < 120) {
                            ctx.beginPath();
                            ctx.strokeStyle = `rgba(0, 102, 255, ${0.15 - distance/120})`;
                            ctx.lineWidth = 1;
                            ctx.moveTo(particles[a].x, particles[a].y);
                            ctx.lineTo(particles[b].x, particles[b].y);
                            ctx.stroke();
                        }
                    }
                }
                
                requestAnimationFrame(animate);
            };

            init();
            animate();
        }
    });
</script>
