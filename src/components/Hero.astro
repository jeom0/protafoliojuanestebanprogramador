---
import { siteData } from '../data/site';
---

<section id="inicio" class="relative min-h-[90vh] flex flex-col justify-center items-center pt-32 pb-20 px-4 md:px-8">
    
    <!-- Massive Centered Typography -->
    <div class="w-full max-w-7xl mx-auto text-center relative z-10 flex flex-col items-center">
        
        <!-- Overhead Intro -->
        <div class="mb-8 inline-flex items-center gap-3 px-6 py-2 rounded-full border border-black/10 bg-white/50 backdrop-blur-sm">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <span class="font-sans text-xs uppercase tracking-widest font-bold text-black/70">JUAN ESTEBAN OSPINA</span>
        </div>

        <!-- Huge Headline (DiegoLiv Style) -->
        <h1 class="font-heading text-[12vw] sm:text-[10vw] md:text-[8vw] lg:text-[140px] leading-[0.8] tracking-[-0.04em] text-black w-full break-words uppercase mix-blend-multiply">
            INGENIERÍA <br/>
            <span class="text-black/30 italic pr-2">DE SOFTWARE</span> <br/>
            DE ALTO NIVEL.
        </h1>
        
        <p class="mt-12 max-w-2xl text-lg md:text-xl font-sans text-black/60 font-medium leading-relaxed">
            {siteData.shortBio} Creo soluciones backend robustas y automatizaciones n8n que escalan.
        </p>

        <!-- CTA Stadium Button -->
        <div class="mt-16 flex flex-col sm:flex-row gap-6 items-center">
            <a href="#contacto" class="stadium-pill bg-black text-white px-10 py-5 text-sm uppercase tracking-widest font-bold font-sans hover:bg-[#0066ff] hover:scale-105 active:scale-95 transition-all duration-300 shadow-xl shadow-black/10 flex items-center gap-3">
                EMPEZAR PROYECTO
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
            
            <a href="#proyectos" class="group flex items-center gap-3 text-black font-sans text-sm font-bold uppercase tracking-widest hover:text-[#0066ff] transition-colors">
                <div class="w-10 h-10 rounded-full border border-black/20 flex items-center justify-center group-hover:border-[#0066ff] transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                </div>
                VER PORTAFOLIO
            </a>
        </div>
    </div>

    <!-- Diegoliv Client Logos Sub-section -->
    <div class="w-full max-w-7xl mx-auto mt-32 pt-16 border-t border-black/10 flex flex-col items-center">
        <p class="font-sans text-[10px] uppercase tracking-[0.3em] text-black/40 font-bold mb-8 text-center">TECNOLOGÍAS PRINCIPALES</p>
        <div class="flex flex-wrap justify-center gap-8 md:gap-16 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
            <!-- Simulating clean monochrome logos -->
            <div class="font-heading text-2xl font-black text-black tracking-tighter">NODE.JS</div>
            <div class="font-heading text-2xl font-black text-black tracking-tighter">PYTHON</div>
            <div class="font-heading text-2xl font-black text-black tracking-tighter">N8N</div>
            <div class="font-heading text-2xl font-black text-black tracking-tighter">DOCKER</div>
            <div class="font-heading text-2xl font-black text-black tracking-tighter">AWS</div>
        </div>
    </div>
</section>
