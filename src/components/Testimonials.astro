    company: "TechVentures",
  },
  {
    quote: "The n8n automations Juan built saved us hundreds of hours every single month. Incredible work and flawless delivery.",
    name: "ANDRÉS GÓMEZ",
    company: "ConsultGroup",
  },
  {
    quote: "Clean architecture, zero latency, zero failures. Genuinely one of the best software engineers I've worked with.",
    name: "MARÍA FERNANDA R.",
    company: "DataSystems",
  },
  {
    quote: "An absolute professional. The entire delivery was ahead of schedule and the code quality was simply unmatched.",
    name: "JORGE LUIS S.",
    company: "InnovateLabs",
  },
  {
    quote: "Su capacidad para resolver problemas complejos de lógica de negocio y arquitectura en AWS nos dejó sin palabras. Un crack.",
    name: "DANIEL OSPINA",
    company: "StartUp Co.",
  },
  {
    quote: "Desde que Juan refactorizó nuestra API de pagos, los errores de conciliación bajaron a cero absoluto. Su código es transparente.",
    name: "VALENTINA PÉREZ",
    company: "Fintech LATAM",
  },
  {
    quote: "Implementó un CRM entero automatizado con n8n y WhatsApp. Las ventas de la empresa subieron un 40% en un mes gracias a eso.",
    name: "SANTIAGO RUÍZ",
    company: "Growth Agency",
  },
  {
    quote: "No solo escribe código rápido, sino que lo diseña para el futuro. El mejor lead backend que he tenido en mi equipo.",
    name: "CAMILA TRUJILLO",
    company: "DevsUnited",
  }
