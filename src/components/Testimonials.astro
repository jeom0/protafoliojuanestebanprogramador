---
const testimonials = [
  {
    quote: "Working with Juan was an absolutely transformative experience for our backend infrastructure. Performance increased by exactly 300%.",
    name: "CARLOS MENDOZA",
    company: "TechVentures",
  },
  {
    quote: "The n8n automations Juan built saved us hundreds of hours every single month. Incredible work and flawless delivery.",
    name: "ANDRÉS GÓMEZ",
    company: "ConsultGroup",
  },
  {
    quote: "Clean architecture, zero latency, zero failures. Genuinely one of the best software engineers I've worked with.",
    name: "MARÍA FERNANDA R.",
    company: "DataSystems",
  },
  {
    quote: "An absolute professional. The entire delivery was ahead of schedule and the code quality was simply unmatched.",
    name: "JORGE LUIS S.",
    company: "InnovateLabs",
  }
];
---

<section id="testimonios-wrapper" class="relative w-full bg-[#f8fafc] overflow-hidden" style="min-height: 100vh;">
  
  <!-- Massive Background Parallax Text -->
  <div class="absolute inset-0 flex items-center justify-center opacity-5 pointer-events-none overflow-hidden select-none z-0">
    <h2 data-gsap="test-bg-text" class="font-heading uppercase text-black font-black whitespace-nowrap" style="font-size: clamp(100px, 25vw, 400px); letter-spacing: -0.05em;">
      CLIENTES FELICES. CLIENTES FELICES.
    </h2>
  </div>

  <div id="testimonios-pin" class="relative w-full h-screen overflow-hidden flex flex-col justify-center items-center z-10" style="perspective: 1500px;">
    
    <!-- Section Label -->
    <p class="absolute top-[10%] md:top-[15%] text-center w-full font-sans text-[10px] font-black uppercase tracking-[0.3em] text-[#0066ff]">
      TESTIMONIOS
    </p>

    <!-- Horizontal Scroll Container -->
    <div id="test-scroll-container" class="flex items-center gap-[10vw] px-[30vw] md:px-[40vw] h-full w-max">
      
      {testimonials.map((t, i) => (
        <div class="test-card w-[85vw] md:w-[60vw] max-w-[800px] bg-white rounded-3xl p-8 md:p-16 flex flex-col gap-8 md:gap-12 relative" style="transform-style: preserve-3d; border: 1px solid rgba(0,0,0,0.05); box-shadow: 0 40px 100px rgba(0,0,0,0.08);">
          
          <svg width="40" height="32" viewBox="0 0 40 32" fill="none" class="absolute top-8 left-8 md:top-12 md:left-12 opacity-10">
            <path d="M0 32V20.267C0 13.333 1.778 8.089 5.333 4.444 8.889 0.8 13.956 -0.444 20.444 0.133V6.222C17.067 6.489 14.489 7.6 12.711 9.556 10.933 11.467 10.044 14.044 10.044 17.244H17.244V32H0ZM22.756 32V20.267C22.756 13.333 24.533 8.089 28.089 4.444 31.644 0.8 36.711 -0.444 43.2 0.133V6.222C39.822 6.489 37.244 7.6 35.467 9.556 33.689 11.467 32.8 14.044 32.8 17.244H40V32H22.756Z" fill="#000"/>
          </svg>

          <p class="font-heading text-2xl md:text-5xl lg:text-[4vw] leading-[1.1] font-black text-black tracking-tighter uppercase relative z-10 pl-4 md:pl-16">
            "{t.quote}"
          </p>
          
          <div class="flex flex-col items-end w-full border-t border-black/10 pt-6 mt-auto">
            <span class="font-sans text-xs md:text-sm font-black uppercase tracking-widest text-black">{t.name}</span>
            <span class="font-sans text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-[#0066ff] mt-1">{t.company}</span>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const wrapper = document.getElementById('testimonios-wrapper');
    const pin = document.getElementById('testimonios-pin');
    const container = document.getElementById('test-scroll-container');
    const cards = gsap.utils.toArray('.test-card');

    if (!wrapper || !pin || !container || cards.length === 0) return;

    // The total distance to scroll horizontally
    let scrollWidth = container.scrollWidth - window.innerWidth;

    // Horizontal Scroll Tween
    const tl = gsap.to(container, {
      x: -scrollWidth,
      ease: "none",
      scrollTrigger: {
        trigger: wrapper,
        pin: pin,
        start: "center center",
        end: () => `+=${scrollWidth}`,
        scrub: 1,
        anticipatePin: 1
      }
    });

    // 3D Rotation Effect for Cards during scroll
    cards.forEach((card: any) => {
      gsap.fromTo(card, 
        {
          rotationY: 45,
          scale: 0.8,
          opacity: 0.2
        },
        {
          rotationY: -45,
          scale: 0.8,
          opacity: 0.2,
          ease: "none",
          scrollTrigger: {
            trigger: card,
            containerAnimation: tl,
            start: "left right",
            end: "right left",
            scrub: true,
            onUpdate: (self) => {
              // Highlight the card when it is near the center
              const progress = self.progress;
              // Gaussian bump: 1 at 0.5, lower at the edges
              const centerDist = Math.abs(progress - 0.5);
              const scale = 0.8 + (1 - centerDist * 2) * 0.2; // peaks at 1.0
              const opacity = 0.2 + (1 - centerDist * 2) * 0.8; // peaks at 1.0
              const rotY = (0.5 - progress) * 90; // rotates from positive to negative
              
              gsap.set(card, {
                rotationY: Math.max(-45, Math.min(45, rotY)),
                scale: Math.max(0.8, Math.min(1, scale)),
                opacity: Math.max(0.2, Math.min(1, opacity)),
                backgroundColor: centerDist < 0.2 ? '#ffffff' : '#f0f0f0'
              });
            }
          }
        }
      );
    });

    // Background Text Parallax
    gsap.to('[data-gsap="test-bg-text"]', {
      xPercent: -30,
      ease: "none",
      scrollTrigger: {
        trigger: wrapper,
        start: "top bottom",
        end: "bottom top",
        scrub: true
      }
    });
  });
</script>
