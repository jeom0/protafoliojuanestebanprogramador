---

<section id="testimonios-wrapper" class="relative w-full bg-[#f8fafc] overflow-hidden py-24 min-h-screen flex flex-col justify-center">

<!-- Background Text -->
<div class="absolute inset-x-0 top-[10%] flex justify-center opacity-[0.06] pointer-events-none select-none">
<h2 class="font-black uppercase text-black text-center leading-[0.8]"
style="font-size: clamp(80px, 14vw, 220px); letter-spacing:-0.05em;">
CLIENTS
</h2>
</div>

<div id="testimonios-pin" class="relative w-full flex justify-center items-center">

<div id="test-scroll-container"
class="relative w-full max-w-5xl h-[520px] flex items-center justify-center"
style="perspective:2000px">

{testimonials.map((t) => (

<div class="test-card absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
w-[92%] md:w-[70%] max-w-[760px]
bg-white rounded-3xl p-10 md:p-14
flex flex-col gap-6 text-center
shadow-[0_35px_80px_rgba(0,0,0,0.15)]
border border-black/5
will-change-transform">

<!-- Quote icon -->
<div class="flex justify-center mb-2 opacity-60">
<svg width="32" height="28" viewBox="0 0 40 32" fill="none">
<path d="M0 32V20.267C0 13.333 1.778 8.089 5.333 4.444 8.889 0.8 13.956 -0.444 20.444 0.133V6.222C17.067 6.489 14.489 7.6 12.711 9.556 10.933 11.467 10.044 14.044 10.044 17.244H17.244V32H0ZM22.756 32V20.267C22.756 13.333 24.533 8.089 28.089 4.444 31.644 0.8 36.711 -0.444 43.2 0.133V6.222C39.822 6.489 37.244 7.6 35.467 9.556 33.689 11.467 32.8 14.044 32.8 17.244H40V32H22.756Z" fill="#000"/>
</svg>
</div>

<p class="font-sans text-lg md:text-2xl leading-relaxed text-[#333] max-w-2xl mx-auto">
{t.quote}
</p>

<div class="pt-4">
<span class="block text-xs font-bold tracking-widest uppercase">
{t.name}
</span>

<span class="block text-[11px] opacity-50 uppercase tracking-[0.2em]">
{t.company}
</span>
</div>

</div>

))}

</div>
</div>

</section>

<script>
import gsap from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

gsap.registerPlugin(ScrollTrigger);

document.addEventListener("DOMContentLoaded", () => {

const cards = gsap.utils.toArray(".test-card");

if(!cards.length) return;

gsap.set(cards, {
transformStyle: "preserve-3d"
});

// estado inicial stack
cards.forEach((card, i) => {

gsap.set(card, {
z: -i * 200,
scale: 1 - i * 0.05,
opacity: i === 0 ? 1 : 0.35
});

});

// timeline
const tl = gsap.timeline({
scrollTrigger: {
trigger: "#testimonios-wrapper",
start: "center center",
end: `+=${cards.length * 300}`,
scrub: 1,
pin: true,
anticipatePin: 1
}
});

// animación
cards.forEach((card, i) => {

if(i === cards.length - 1) return;

const next = cards[i + 1];

tl.to(card, {
z: 250,
scale: 1.15,
opacity: 0,
duration: 1,
ease: "power2.inOut"
}, i);

tl.to(next, {
z: 0,
scale: 1,
opacity: 1,
duration: 1,
ease: "power2.inOut"
}, i);

});

});
</script>