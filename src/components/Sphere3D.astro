---
---
<div class="relative w-[300px] h-[300px] md:w-[500px] md:h-[500px] floating-3d-asset">
  <svg viewBox="0 0 200 200" class="w-full h-full">
    <!-- Outer Glass Ring -->
    <circle cx="100" cy="100" r="90" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="0.5" />
    
    <!-- Central Mesh Sphere -->
    <defs>
      <radialGradient id="sphereGradient" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#00FF88" stop-opacity="0.1" />
        <stop offset="100%" stop-color="#000" stop-opacity="0" />
      </radialGradient>
      
      <filter id="glow">
        <feGaussianBlur stdDeviation="3" result="blur" />
        <feComposite in="SourceGraphic" in2="blur" operator="over" />
      </filter>
    </defs>
    
    <circle cx="100" cy="100" r="60" fill="url(#sphereGradient)" />
    
    <!-- Internal Nodes & Connections -->
    <g class="nodes-group">
      <circle cx="100" cy="100" r="2" fill="#00FF88" filter="url(#glow)" />
      <circle cx="140" cy="80" r="1.5" fill="#00FF88" filter="url(#glow)" />
      <circle cx="60" cy="120" r="1.5" fill="#00FF88" filter="url(#glow)" />
      <circle cx="110" cy="140" r="1.5" fill="#00FF88" filter="url(#glow)" />
      
      <line x1="100" y1="100" x2="140" y2="80" stroke="#00FF88" stroke-width="0.2" stroke-opacity="0.3" />
      <line x1="100" y1="100" x2="60" y2="120" stroke="#00FF88" stroke-width="0.2" stroke-opacity="0.3" />
      <line x1="100" y1="100" x2="110" y2="140" stroke="#00FF88" stroke-width="0.2" stroke-opacity="0.3" />
    </g>

    <!-- Orbital Rings -->
    <ellipse cx="100" cy="100" rx="80" ry="30" fill="none" stroke="white" stroke-opacity="0.1" stroke-width="0.5" class="orbital-1" />
    <ellipse cx="100" cy="100" rx="40" ry="90" fill="none" stroke="#00FF88" stroke-opacity="0.2" stroke-width="0.5" class="orbital-2" />
  </svg>
</div>

<style>
  .floating-3d-asset {
      animation: float 6s ease-in-out infinite;
  }
  
  .nodes-group {
      animation: rotate-nodes 20s linear infinite;
      transform-origin: center;
  }

  .orbital-1 {
      transform-origin: center;
      animation: orbit 15s linear infinite;
  }

  .orbital-2 {
      transform-origin: center;
      animation: orbit 10s linear reverse infinite;
  }

  @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(2deg); }
  }

  @keyframes rotate-nodes {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
  }

  @keyframes orbit {
      from { transform: rotate3d(1, 1, 0, 0deg); }
      to { transform: rotate3d(1, 1, 0, 360deg); }
  }
</style>
