---
import { projects } from '../data/projects';
---

<section id="proyectos" class="py-32 relative z-10 w-full overflow-hidden">
  
  <!-- Massive Background Scrolling Text -->
  <div class="absolute top-0 left-0 w-full overflow-hidden whitespace-nowrap opacity-5 pointer-events-none select-none z-0">
      <h2 class="font-heading text-[30vw] text-black uppercase tracking-tighter mix-blend-multiply flex animate-scroll-left">
          <span>SELECTED WORK&nbsp;&mdash;&nbsp;SELECTED WORK&nbsp;&mdash;&nbsp;</span>
          <span>SELECTED WORK&nbsp;&mdash;&nbsp;SELECTED WORK&nbsp;&mdash;&nbsp;</span>
      </h2>
  </div>

  <div class="container mx-auto px-4 md:px-8 max-w-[1400px] relative z-10">
    
    <!-- Massive Section Title -->
    <div class="mb-24 md:mb-32">
        <h2 class="font-heading text-[12vw] sm:text-[10vw] md:text-[8vw] leading-[0.85] text-black uppercase tracking-tighter mix-blend-multiply">
            PROYECTOS <br/>
            DESTACADOS.
        </h2>
    </div>

    <!-- Vertical Stack of DiegoLiv Pill Projects -->
    <div class="flex flex-col gap-32">
      {projects.map((project, index) => (
        <div class="w-full relative group block">
            
            <!-- Information Layer (DiegoLiv style text on top of or below image) -->
            <div class="flex flex-col lg:flex-row justify-between items-end mb-6 pl-4 lg:pl-8 border-l-4 border-black/10 group-hover:border-[#0066ff] transition-colors duration-500">
                <div class="w-full max-w-2xl">
                    <h3 class="font-heading text-5xl md:text-6xl lg:text-7xl uppercase font-black text-black tracking-tighter leading-[0.85] mb-4 group-hover:text-[#0066ff] transition-colors">{project.title}</h3>
                    <p class="font-sans text-lg md:text-xl text-black/60 font-medium leading-relaxed">{project.desc}</p>
                </div>
                
                <div class="mt-6 lg:mt-0 flex gap-2">
                    <span class="px-5 py-2 rounded-full border border-black/10 text-black font-sans text-xs uppercase font-bold tracking-widest bg-white">Desarrollo</span>
                    <span class="px-5 py-2 rounded-full border border-black/10 text-black font-sans text-xs uppercase font-bold tracking-widest bg-white z-10">n8n</span>
                </div>
            </div>

            <!-- The Image Container (Pill Shaped/Huge Border Radius) -->
            <div class="diegoliv-card w-full h-[50vh] md:h-[80vh] overflow-hidden relative cursor-default">
                {index === 0 && <img src="/images/project-conduser.png" alt={project.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-[1s] ease-[cubic-bezier(0.25,1,0.5,1)]" />}
                {index === 1 && <img src="/images/project-instagram.png" alt={project.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-[1s] ease-[cubic-bezier(0.25,1,0.5,1)]" />}
                
                {/* Custom WhatsApp SVG Composition for High-Fidelity */}
                {index === 2 && (
                    <div class="w-full h-full bg-gradient-to-br from-[#128C7E] to-[#075E54] flex items-center justify-center transform group-hover:scale-105 transition-transform duration-[1s] ease-[cubic-bezier(0.25,1,0.5,1)] relative overflow-hidden">
                        <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_center,_#25D366_0%,_transparent_100%)]"></div>
                        <svg class="w-40 h-40 md:w-64 md:h-64 text-white drop-shadow-2xl relative z-10 transition-transform duration-500 group-hover:-translate-y-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M11.993 0C5.367 0 0 5.366 0 11.995c0 2.65.86 5.105 2.308 7.15L.892 24l5.006-1.314c1.954 1.258 4.29 1.986 6.784 1.986C19.317 24 24 18.634 24 12c0-6.63-5.366-12-12.007-12zm6.657 17.185c-.279.789-1.545 1.517-2.128 1.579-.536.056-1.228.096-3.411-.806-2.774-1.144-4.551-4.008-4.691-4.194-.14-.186-1.121-1.492-1.121-2.844 0-1.352.704-2.016.953-2.28.249-.264.544-.33.722-.33.179 0 .358.008.514.016.163.008.381-.062.599.467.225.544 1.057 2.58.1149 2.766.093.187-.031.296-.124.436-.093.14-.194.303-.279.389-.093.093-.194.194-.085.381.109.187.482.793 1.034 1.284.711.63 1.306.824 1.492.918.187.093.296.078.405-.031.109-.109.474-.552.599-.739.124-.187.249-.156.419-.093.171.062 1.081.513 1.267.607.187.093.311.14.358.218.047.078.047.451-.233 1.24z"/>
                        </svg>
                    </div>
                )}
                {index > 2 && <div class="w-full h-full bg-[#E2E8F0] transform group-hover:scale-105 transition-transform duration-700"></div>}
                
                <!-- Overlay "View Details" badge -->
                <div class="absolute bottom-8 right-8 bg-black text-white px-6 py-4 rounded-full font-sans text-xs font-bold uppercase tracking-widest shadow-2xl opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 z-20 flex items-center gap-2">
                    VER MÁS <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </div>
            </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
    @keyframes scroll-left {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-scroll-left {
        animation: scroll-left 40s linear infinite;
        width: 200%;
    }
</style>
