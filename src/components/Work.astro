---
import { projects } from '../data/projects';
---

<section id="proyectos" class="relative z-10 w-full bg-white">

  <!-- The pinned viewport — stays fixed while scroll-space triggers -->
  <div id="work-pin-wrapper" class="relative">

    <!-- Fixed visual container (pinned by GSAP) -->
    <div id="work-pinned-container" class="w-full h-screen flex items-center justify-center relative overflow-hidden bg-white">
      
      <!-- Giant Background Title (changes per project) -->
      <div class="absolute inset-0 flex items-center overflow-hidden pointer-events-none z-0 select-none">
        <h2 id="work-bg-title" class="font-heading uppercase text-black leading-[1.1] md:leading-[0.8] tracking-tight md:tracking-tighter whitespace-nowrap"
          style="font-size: clamp(80px, 20vw, 240px); opacity: 0.06; transform: translateX(0);">
          {projects[0].title}
        </h2>
      </div>

      <!-- Centered Card Stack -->
      <div id="work-card-stack" class="relative w-[90vw] md:w-[55vw] max-w-[700px] z-10"
           style="perspective: 1800px; transform-style: preserve-3d;">
        
        {projects.map((project, i) => (
          <div
            id={`project-card-${i}`}
            class="project-card absolute top-0 left-0 w-full origin-top cursor-pointer"
            style={`
              z-index: ${projects.length - i};
              transform-origin: center top;
              backface-visibility: hidden;
              ${i === 0 ? 'position: relative;' : 'opacity: 0; transform: rotateX(-90deg) translateY(-20px);'}
            `}
            data-modal={`modal-project-${i}`}
          >
            <!-- Card Visual -->
            <div class="w-full rounded-[24px] overflow-hidden bg-white shadow-[0_30px_80px_rgba(0,0,0,0.18)] border border-black/5 group">
              
              <!-- Project Screenshot -->
              <div class="w-full aspect-[16/9] overflow-hidden bg-[#e8edf2] relative">
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  onerror="this.src='https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80'"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end justify-center pb-8">
                  <span class="bg-white text-black px-6 py-3 rounded-full font-sans text-[10px] uppercase font-black tracking-widest shadow-xl mb-4">VER DETALLES</span>
                </div>
              </div>

              <!-- Card Info Bar -->
              <div class="flex items-center justify-between px-6 py-5 bg-white">
                <div>
                  <h3 class="font-heading font-black text-xl md:text-2xl uppercase tracking-tighter text-black leading-none">{project.title}</h3>
                  <p class="text-[10px] md:text-xs font-sans font-medium text-black/40 uppercase tracking-widest mt-1">{project.tags.join(', ')}</p>
                </div>
                <div class="px-5 py-3 rounded-full bg-black text-white font-sans text-[10px] uppercase font-black tracking-widest whitespace-nowrap hover:bg-[#0066ff] transition-colors">
                  VIEW PROJECT
                </div>
              </div>

            </div>
          </div>
        ))}

      </div>

      <!-- Project Counter -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-3 z-20">
        {projects.map((_, i) => (
          <div id={`project-dot-${i}`} class="project-dot w-2 h-2 rounded-full transition-all duration-500" style={i === 0 ? 'background: #000; width: 24px;' : 'background: rgba(0,0,0,0.2);'} />
        ))}
      </div>

    </div>
  </div>

  <!-- ==================== PROJECT MODALS ==================== -->
  <div id="project-modals">
    {projects.map((project, i) => (
      <dialog id={`modal-project-${i}`} class="bg-transparent m-auto p-0 w-full h-full max-w-none max-h-none backdrop:bg-black/80 backdrop:backdrop-blur-sm fixed inset-0 z-[400] hidden">
        <div class="w-full h-full flex items-center justify-center p-4 sm:p-8">
          <div class="bg-[#F2F2F2] w-full max-w-5xl max-h-[90vh] rounded-[32px] shadow-2xl overflow-hidden flex flex-col relative transform scale-95 opacity-0 transition-all duration-500 modal-content">
            
            <!-- Close Button -->
            <div class="absolute top-5 right-5 z-50">
              <button type="button" class="w-12 h-12 bg-black text-white rounded-full flex items-center justify-center hover:bg-[#0066ff] hover:rotate-90 transition-all duration-300 shadow-lg close-modal-btn" data-modal={`modal-project-${i}`}>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
            <span class="absolute top-5 left-5 z-50 px-4 py-2 rounded-full bg-white border border-black/10 text-black font-sans text-[10px] uppercase font-black tracking-widest">{project.title}</span>

            <!-- Scrollable Body -->
            <div class="w-full flex-1 overflow-y-auto">
              <div class="w-full h-[45vh] relative bg-[#E2E8F0] shrink-0">
                <img src={project.image} alt={project.title} class="w-full h-full object-cover" onerror="this.src='https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80'" />
                <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#F2F2F2] to-transparent"></div>
              </div>
              <div class="p-8 md:p-14 flex flex-col md:flex-row gap-8 md:gap-12 bg-[#F2F2F2]">
                <div class="md:w-2/3">
                  <h3 class="font-heading text-5xl md:text-7xl font-black text-black uppercase tracking-tight md:tracking-tighter leading-[1.1] md:leading-[0.85] mb-4 md:mb-6">{project.title}</h3>
                  <p class="font-sans text-base md:text-lg text-black/70 font-medium leading-relaxed mb-4 md:mb-6">{project.summary}</p>
                  <ul class="space-y-2 mb-8">
                    {project.impactBullets.map(b => (
                      <li class="flex items-start gap-3 text-sm font-medium text-black/60 font-sans">
                        <span class="w-1.5 h-1.5 rounded-full bg-[#0066ff] mt-2 shrink-0"></span>{b}
                      </li>
                    ))}
                  </ul>
                  <div class="flex flex-wrap gap-2">
                    {project.tags.map(t => (
                      <span class="px-4 py-2 rounded-full border border-black/10 text-black font-sans text-[10px] uppercase font-bold tracking-widest bg-white">{t}</span>
                    ))}
                  </div>
                </div>
                <div class="md:w-1/3 flex flex-col items-start md:items-end pt-0 md:pt-2">
                  <p class="text-[10px] font-bold uppercase tracking-widest text-[#0066ff] mb-4">ENLACE AL PROYECTO</p>
                  <a href={project.url} target="_blank" class="w-full md:w-auto px-8 py-4 bg-black text-white rounded-full text-[10px] uppercase tracking-widest font-black font-sans hover:bg-[#0066ff] transition-all duration-300 shadow-xl flex items-center justify-center gap-3 group">
                    VISITAR SITIO
                    <svg class="w-4 h-4 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                  </a>
                </div>
              </div>
            </div>

          </div>
        </div>
      </dialog>
    ))}
  </div>

</section>

<script is:inline define:vars={{ projects }}>
  window.portfolioProjects = projects;
</script>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(10px);
  }
  dialog[open] .modal-content {
    opacity: 1 !important;
    transform: scale(1) !important;
  }
  .project-card {
    transform-style: preserve-3d;
    will-change: transform, opacity;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const projectsData = (window as any).portfolioProjects || [];
    if (projectsData.length === 0) return;

    const pinContainer = document.getElementById('work-pinned-container');
    const bgTitle       = document.getElementById('work-bg-title');
    const cardStack     = document.getElementById('work-card-stack');
    const cards         = document.querySelectorAll('.project-card');
    const dots          = document.querySelectorAll('.project-dot');

    // ---- Modal Logic ----
    document.querySelectorAll('[data-modal]').forEach(trigger => {
      const el = trigger as HTMLElement;
      el.addEventListener('click', () => {
        if(el.closest('.project-card')) {
          const id = el.getAttribute('data-modal');
          const dialog = document.getElementById(id!) as HTMLDialogElement;
          if(dialog) {
            dialog.style.display = 'flex';
            dialog.showModal();
            document.body.style.overflow = 'hidden';
          }
        }
      });
    });

    document.querySelectorAll('.close-modal-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLElement).getAttribute('data-modal');
        const dialog = document.getElementById(id!) as HTMLDialogElement;
        if(dialog) {
          const content = dialog.querySelector('.modal-content') as HTMLElement;
          if(content) { content.style.opacity = '0'; content.style.transform = 'scale(0.95)'; }
          setTimeout(() => { dialog.close(); dialog.style.display = 'none'; if(content){ content.style.opacity = ''; content.style.transform = ''; } document.body.style.overflow = ''; }, 450);
        }
      });
    });

    // ---- GSAP Scroll Flip ----
    if (!pinContainer || cards.length === 0) return;

    // Tracker for current active card
    let currentCard = 0;

    function activateDot(index: number) {
      dots.forEach((dot, i) => {
        const el = dot as HTMLElement;
        if(i === index) { el.style.background = '#000'; el.style.width = '24px'; }
        else { el.style.background = 'rgba(0,0,0,0.2)'; el.style.width = '8px'; }
      });
      if(bgTitle) bgTitle.textContent = projectsData[index]?.title || '';
    }

    // Initial state: first card visible, rest hidden behind
    gsap.set(cards[0], { rotationX: 0, opacity: 1, y: 0 });
    for(let i = 1; i < cards.length; i++) {
      gsap.set(cards[i], { rotationX: -90, opacity: 0, y: -20 });
    }

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '#proyectos',
        start: 'top top',
        end: () => `+=${(cards.length - 1) * 40}vh`,
        scrub: 1,
        pin: pinContainer,
        anticipatePin: 1,
        onUpdate: (self) => {
          // Determine which card should be active
          const totalProgress = self.progress;
          const segment = 1 / (cards.length - 1);
          const targetCard = Math.min(
            Math.floor(totalProgress / segment),
            cards.length - 1
          );
          if(targetCard !== currentCard) {
            currentCard = targetCard;
            activateDot(currentCard);
          }
        }
      }
    });

    // For each transition: flip OUT the current card (rotate forward), flip IN next card
    for(let i = 0; i < cards.length - 1; i++) {
      const outCard = cards[i] as HTMLElement;
      const inCard  = cards[i + 1] as HTMLElement;

      tl.to(outCard, {
        rotationX: 90,
        opacity: 0,
        y: 60,
        duration: 0.5,
        ease: 'power2.in',
      });

      tl.fromTo(inCard,
        { rotationX: -90, opacity: 0, y: -40 },
        { rotationX: 0, opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }
      );
    }
  });
</script>
