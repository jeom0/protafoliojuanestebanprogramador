---
import { projects } from '../data/projects';
---

<section id="proyectos" class="py-12 md:py-32 relative z-10 w-full overflow-hidden">
  
  <!-- Massive Background Scrolling Text -->
  <div class="absolute top-0 left-0 w-full overflow-hidden whitespace-nowrap opacity-5 pointer-events-none select-none z-0">
      <h2 class="font-heading text-[30vw] text-black uppercase tracking-tighter mix-blend-multiply flex animate-scroll-left">
          <span>SELECTED WORK&nbsp;&mdash;&nbsp;SELECTED WORK&nbsp;&mdash;&nbsp;</span>
          <span>SELECTED WORK&nbsp;&mdash;&nbsp;SELECTED WORK&nbsp;&mdash;&nbsp;</span>
      </h2>
  </div>

  <div class="container mx-auto px-4 md:px-8 max-w-[1400px] relative z-10">
    <!-- Massive Section Title -->
    <div class="mb-16 md:mb-24 flex justify-between items-end relative">
        <h2 class="font-heading text-[12vw] sm:text-[10vw] md:text-[8vw] leading-[0.85] text-black uppercase tracking-tighter mix-blend-multiply">
            PROYECTOS <br/>
            DESTACADOS.
        </h2>
        
        <!-- Rotating SVG Badge (Diegoliv Style) -->
        <div class="hidden md:flex absolute right-0 bottom-0 w-32 h-32 md:w-40 md:h-40 items-center justify-center pointer-events-none z-20">
            <svg data-gsap="rotate-badge" class="w-full h-full text-black origin-center" viewBox="0 0 100 100">
                <defs>
                    <path id="circlePath" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" />
                </defs>
                <text font-family="Inter, sans-serif" font-weight="bold" font-size="10" letter-spacing="4.5" fill="currentColor">
                    <textPath href="#circlePath">
                        SCROLL DOWN • DISCOVER WORK • 
                    </textPath>
                </text>
                <!-- Inner Arrow -->
                <path fill="currentColor" d="M50 35 L60 45 L52 45 L52 65 L48 65 L48 45 L40 45 Z" class="opacity-50" />
            </svg>
        </div>
    </div>
  </div>

  <!-- ============================================== -->
  <!-- MODALS (Hidden by default, opened via JS)      -->
  <!-- ============================================== -->
  <div id="project-modals">
      {projects.map((project, index) => (
          <dialog id={`modal-project-${index}`} class="bg-transparent m-auto p-0 w-full h-full max-w-none max-h-none backdrop:bg-black/80 backdrop:backdrop-blur-sm fixed inset-0 z-[300] hidden overflow-hidden">
              <div class="w-full h-full flex items-center justify-center p-4 sm:p-8">
                  <div class="bg-[#F2F2F2] w-full max-w-6xl h-[90vh] rounded-[48px] shadow-2xl overflow-hidden flex flex-col relative transform scale-95 opacity-0 transition-all duration-500 modal-content">
                      
                      <!-- Modal Header / Close -->
                      <div class="w-full px-8 pt-8 flex justify-between items-start absolute top-0 left-0 z-50">
                          <span class="px-5 py-2 rounded-full border border-black/10 bg-white/80 backdrop-blur-md text-black font-sans text-xs uppercase font-bold tracking-widest">{project.title}</span>
                          <button type="button" class="w-14 h-14 bg-black text-white rounded-full flex items-center justify-center hover:bg-[#0066ff] hover:rotate-90 transition-all duration-300 shadow-lg close-modal-btn" data-modal={`modal-project-${index}`}>
                              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                          </button>
                      </div>

                      <!-- Modal Body: Image -->
                      <div class="w-full h-[50vh] relative bg-[#E2E8F0]">
                          <img src={`/images/project-${index === 0 ? 'conduser' : index === 1 ? 'instagram' : 'whatsapp'}.png`} alt={project.title} class="w-full h-full object-cover" onerror="this.src='https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80'" />
                          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#F2F2F2]"></div>
                      </div>

                      <!-- Modal Body: Content -->
                      <div class="flex-1 p-8 md:p-16 flex flex-col md:flex-row gap-12 overflow-y-auto bg-[#F2F2F2]">
                          <div class="md:w-1/2">
                              <h3 class="font-heading text-6xl md:text-8xl font-black text-black uppercase tracking-tighter leading-[0.8] mb-8">{project.title}</h3>
                              <p class="font-sans text-lg text-black/60 font-medium leading-relaxed mb-8">{project.desc}</p>
                              
                              <div class="flex flex-wrap gap-2">
                                  {project.tags.map(t => (
                                      <span class="px-5 py-2 rounded-full border border-black/10 text-black font-sans text-xs uppercase font-bold tracking-widest bg-white">{t}</span>
                                  ))}
                              </div>
                          </div>
                          <div class="md:w-1/2 flex flex-col justify-end items-start md:items-end">
                              <a href={project.url} target="_blank" class="stadium-pill bg-black text-white px-10 py-5 text-sm uppercase tracking-widest font-bold font-sans hover:bg-[#0066ff] transition-all duration-300 shadow-xl shadow-black/10 flex items-center gap-3 w-full md:w-auto justify-center group">
                                  VISITAR SITIO
                                  <svg class="w-4 h-4 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                              </a>
                          </div>
                      </div>
                  </div>
              </div>
          </dialog>
      ))}
  </div>

  <!-- ============================================== -->
  <!-- MOBILE VERTICAL STACK (Hidden on Desktop)      -->
  <!-- ============================================== -->
  <div class="flex flex-col gap-12 md:hidden px-4 mt-12">
    {projects.map((project, index) => (
      <div class="w-full relative group block" data-gsap="work-card">
          <div class="mb-4 pl-4 border-l-4 border-black/10">
              <h3 class="font-heading text-5xl uppercase font-black text-black tracking-tighter leading-none mb-2">{project.title}</h3>
          </div>
          <div class="diegoliv-card w-full h-[60vh] overflow-hidden relative cursor-pointer open-modal-btn" data-modal={`modal-project-${index}`}>
              <img src={`/images/project-${index === 0 ? 'conduser' : index === 1 ? 'instagram' : 'whatsapp'}.png`} alt={project.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" onerror="this.src='https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80'" />
              
              <div class="absolute bottom-6 right-6 bg-black text-white px-5 py-3 rounded-full font-sans text-[10px] font-bold uppercase tracking-widest shadow-2xl z-20 flex items-center gap-2">
                  VER MÁS <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </div>
          </div>
      </div>
    ))}
  </div>

  <!-- ============================================== -->
  <!-- DESKTOP HORIZONTAL PIN (Hidden on Mobile)      -->
  <!-- ============================================== -->
  <div id="desktop-work-pin" class="hidden md:flex h-[100vh] w-full items-center overflow-hidden relative">
      <div id="desktop-work-slider" class="flex gap-16 px-16 h-[75vh] items-center whitespace-nowrap" style="width: max-content;">
          
          {projects.map((project, index) => (
            <div class="w-[70vw] h-full shrink-0 relative group block flex gap-12 items-end">
                
                <!-- Inner Layout: Info Left, Image Right -->
                <div class="w-[30%] flex flex-col justify-end pb-12 opacity-0 -translate-x-12 desktop-info">
                    <h3 class="font-heading text-7xl lg:text-8xl uppercase font-black text-black tracking-tighter leading-[0.85] mb-6 group-hover:text-[#0066ff] transition-colors overflow-hidden whitespace-normal">{project.title}</h3>
                    <p class="font-sans text-xl text-black/60 font-medium leading-relaxed whitespace-normal mb-8 max-w-sm">{project.desc}</p>
                    <div class="flex gap-2 flex-wrap max-w-sm">
                        <span class="px-5 py-2 rounded-full border border-black/10 text-black font-sans text-xs uppercase font-bold tracking-widest bg-white">Desarrollo</span>
                    </div>
                </div>

                <div class="w-[70%] h-full diegoliv-card overflow-hidden relative cursor-pointer shadow-xl open-modal-btn" data-modal={`modal-project-${index}`}>
                    <img data-gsap="parallax-horiz-img" src={`/images/project-${index === 0 ? 'conduser' : index === 1 ? 'instagram' : 'whatsapp'}.png`} alt={project.title} class="w-[120%] h-full object-cover absolute top-0 left-0 transform origin-center transition-transform duration-700 group-hover:scale-105" onerror="this.src='https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80'" />
                    
                    <div class="absolute bottom-8 right-8 bg-black text-white px-6 py-4 rounded-full font-sans text-xs font-bold uppercase tracking-widest shadow-2xl opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 z-20 flex items-center gap-2">
                        VER MÁS <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </div>
                </div>

            </div>
          ))}

      </div>
  </div>

</section>

<style>
    @keyframes scroll-left {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-scroll-left {
        animation: scroll-left 40s linear infinite;
        width: 200%;
    }
    
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(8px);
    }
    
    /* Open animation for modal content */
    dialog[open] .modal-content {
        opacity: 1;
        transform: scale(1);
    }
</style>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // Horizontal Scroll Marquee Speed-up on vertical scroll
        const marquee = document.querySelector('.animate-scroll-left');
        if (marquee) {
            ScrollTrigger.create({
                trigger: document.body,
                start: "top top",
                end: "bottom bottom",
                onUpdate: (self) => {
                    const velocity = Math.abs(self.getVelocity() / 100);
                    gsap.to(marquee, { x: `-=${velocity}`, force3D: true, duration: 0.1 });
                }
            });
        }

        // Rotating Badge Scroll connection
        gsap.to('[data-gsap="rotate-badge"]', {
            rotation: 360,
            ease: "none",
            scrollTrigger: {
                trigger: "body",
                start: "top top",
                end: "bottom bottom",
                scrub: 1
            }
        });

        // Modals Logic
        const openBtns = document.querySelectorAll('.open-modal-btn');
        const closeBtns = document.querySelectorAll('.close-modal-btn');
        
        openBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const targetId = (e.currentTarget as HTMLElement).getAttribute('data-modal');
                if(targetId) {
                    const dialog = document.getElementById(targetId) as HTMLDialogElement;
                    if(dialog) {
                        dialog.style.display = 'flex'; // required for centering before showing
                        dialog.showModal();
                        document.body.style.overflow = 'hidden';
                    }
                }
            });
        });

        closeBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const targetId = (e.currentTarget as HTMLElement).getAttribute('data-modal');
                if(targetId) {
                    const dialog = document.getElementById(targetId) as HTMLDialogElement;
                    if(dialog) {
                        const content = dialog.querySelector('.modal-content') as HTMLElement;
                        content.style.opacity = '0';
                        content.style.transform = 'scale(0.95)';
                        setTimeout(() => {
                            dialog.close();
                            dialog.style.display = 'none';
                            content.style.opacity = '';
                            content.style.transform = '';
                            document.body.style.overflow = '';
                        }, 500); // Wait for CSS transition
                    }
                }
            });
        });

        // Desktop Horizontal Scroll GSAP Pin
        if (window.innerWidth >= 768) {
            const pinWrapper = document.getElementById('desktop-work-pin');
            const slider = document.getElementById('desktop-work-slider');
            
            if (pinWrapper && slider) {
                // Calculate how far to scroll to reach the end of the slider
                const xDist = -(slider.scrollWidth - window.innerWidth + 128); // 128px padding compensation
                
                const scrollTween = gsap.to(slider, {
                    x: xDist,
                    ease: "none",
                    scrollTrigger: {
                        trigger: pinWrapper,
                        pin: true,
                        scrub: 1,
                        end: () => "+=" + slider.scrollWidth
                    }
                });

                // Animate info text strictly bounded to container viewport entrance
                const infos = document.querySelectorAll('.desktop-info');
                infos.forEach((info) => {
                    gsap.to(info, {
                        opacity: 1,
                        x: 0,
                        duration: 1,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: info.parentNode,
                            containerAnimation: scrollTween,
                            start: "left center", // Trigger when the item reaches middle
                            toggleActions: "play none none reverse"
                        }
                    });
                });

                // Horiz Image Parallax (Image moves slightly opposite to scroll)
                const imgs = document.querySelectorAll('[data-gsap="parallax-horiz-img"]');
                imgs.forEach((img) => {
                    gsap.to(img, {
                        xPercent: 15,
                        ease: "none",
                        scrollTrigger: {
                            trigger: img.parentNode,
                            containerAnimation: scrollTween,
                            start: "left right",
                            end: "right left",
                            scrub: true
                        }
                    });
                });
            }
        } else {
            // Mobile Card Vertical Animations
            const cards = document.querySelectorAll('[data-gsap="work-card"]');
            cards.forEach((card) => {
                gsap.from(card, {
                    y: 100,
                    opacity: 0,
                    duration: 1.2,
                    ease: 'power3.out',
                    scrollTrigger: {
                        trigger: card,
                        start: "top 85%",
                        toggleActions: "play none none reverse"
                    }
                });
            });
        }
    });
</script>
